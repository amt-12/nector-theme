      "blocks": {
        "ai_gen_block_546fabf_8zXcY6": {
          "type": "ai_gen_block_546fabf",
          "settings": {
            "heading": "Our Commitments",
            "subheading": "​",
            "commitment_1_title": "MINIMAL INPUTS",
            "commitment_1_description": "Nature is the craftsman. Our role is to protect the integrity of the hive — no unnecessary interventions, no additives, no shortcuts. What you taste is the landscape itself.",
            "commitment_2_title": "COLD EXTRACTION ONLY",
            "commitment_2_description": "Heat destroys what makes honey remarkable. Every batch is cold-extracted to preserve the full spectrum of natural enzymes, pollen, and terroir-driven flavour — exactly as the comb intended.",
            "commitment_3_title": "GLASS PACKAGING & SNAP-CLICK SACHETS",
            "commitment_3_description": "Glass is the only vessel worthy of what's inside. Our jars are inert, reusable, and infinitely recyclable — preserving purity without compromise. Our snap-click sachets are single-dose and crafted from 100% recyclable mono-material polypropylene — a considered choice for on-the-go without unnecessary waste.",
            "commitment_4_title": "DIRECT SOURCING",
            "commitment_4_description": "We source directly from migratory beekeepers whose knowledge spans generations and landscapes. Every origin is known, every relationship is built on trust and fair exchange.",
            "commitment_5_title": "FSSAI CERTIFIED",
            "commitment_5_description": "Our standards exceed compliance. FSSAI certification is the baseline — our commitment to quality is the practice that precedes it, in every batch, every season.",
            "closing_text": "— Purity is not a claim. It is a practice.",
            "background_color": "#f5f0e8",
            "heading_color": "#1a1a1a",
            "text_color": "#1a1a1a",
            "accent_color": "#c8922a",
            "heading_font": "cormorant_n4",
