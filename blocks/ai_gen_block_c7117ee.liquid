{% doc %}
  @prompt
    Regenerate this exact full-width hero banner block for a luxury honey brand — the "10 grams of ritual" Snap-Click Sachets section. Keep ALL settings exactly the same but change the spacing_after_price range slider maximum from 60px to 120px so it can be set to 100px.
    
    Exact settings to replicate:
    - background_image image picker (current: gid://shopify/MediaImage/41225743302907)
    - min_height_desktop range slider 300–800px (current: 600px)
    - min_height_mobile range slider 200–700px (current: 500px)
    - headline text field (current: "10 grams of ritual.")
    - headline_size range slider 24–120px (current: 64px)
    - spacing_after_headline range slider 0–80px (current: 24px)
    - subtext textarea (current: "The Snap-Click Sachet. Precision-portioned. Entirely intentional.")
    - subtext_size range slider 12–32px (current: 18px)
    - spacing_after_subtext range slider 0–80px (current: 32px)
    - price_text text field (current: "Starting from ₹299")
    - price_size range slider 12–32px (current: 20px)
    - spacing_after_price range slider 0–120px (current: 60px) — EXTENDED MAX to 120px
    - text_color color picker (current: #ffffff)
    - button_label text field (current: "Shop Snap-Click Sachets")
    - button_link URL field (current: shopify://collections/20-day-pack)
    - button_text_size range slider (current: 16px)
    - button_padding_vertical range slider (current: 14px)
    - button_padding_horizontal range slider (current: 32px)
    - button_text_color color picker (current: #ffffff)
    - button_background_color color picker (current: transparent/rgba(0,0,0,0))
    - button_border_color color picker (current: #ffffff)
    - button_border_width range slider (current: 1px)
    - button_border_radius range slider (current: 0px)
    - button_hover_text_color color picker (current: #1a1a1a)
    - button_hover_background_color color picker (current: #ffffff)
    - button_hover_border_color color picker (current: #ffffff)
    Design: full-bleed background image with text overlay, ultra-luxury, Cormorant serif for headline, all text left-aligned, white text on dark image., the backgorund image is not full page width. please make it full page width 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    min-height: {{ block.settings.min_height_desktop }}px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .ai-hero-banner__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 40px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-banner__headline-{{ ai_gen_id }} {
    font-family: 'var(--font-heading--family)';
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.2;
    margin: 0 0 {{ block.settings.spacing_after_headline }}px 0;
    font-weight: 400;
  }

  .ai-hero-banner__subtext-{{ ai_gen_id }} {
     font-family: 'var(--font-body--family)';
    font-size: {{ block.settings.subtext_size }}px;
    line-height: 1.5;
    margin: 0 0 {{ block.settings.spacing_after_subtext }}px 0;
    max-width: 600px;
  }

  .ai-hero-banner__price-{{ ai_gen_id }} {
    font-family: 'var(--font-body--family)';
    font-size: {{ block.settings.price_size }}px;
    line-height: 1.4;
    margin: 0 0 {{ block.settings.spacing_after_price }}px 0;
    font-weight: 500;
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-family: 'raleway';
    font-size: {{ block.settings.button_text_size }}px;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_background_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-hero-banner__button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_hover_text_color }};
    background-color: {{ block.settings.button_hover_background_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-hero-banner__content-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-hero-banner__headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.6);
    }

    .ai-hero-banner__subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtext_size }}px * 0.9);
    }

    .ai-hero-banner__price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.price_size }}px * 0.9);
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.button_text_size }}px * 0.9);
      padding: calc({{ block.settings.button_padding_vertical }}px * 0.85) calc({{ block.settings.button_padding_horizontal }}px * 0.85);
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-banner__background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-banner__content-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-banner__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-hero-banner__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    {% if block.settings.price_text != blank %}
      <p class="ai-hero-banner__price-{{ ai_gen_id }}">{{ block.settings.price_text }}</p>
    {% endif %}

    {% if block.settings.button_label != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-hero-banner__button-{{ ai_gen_id }}">
        {{ block.settings.button_label }}
      </a>
    {% endif %}
  </div>
</div>

