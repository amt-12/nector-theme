{% doc %}
  @prompt
    Create a contact page layout with two parts:
    
    Part 1 — Split Hero Full-width split layout. Left half: dark warm olive/charcoal background (#2c2a25), small uppercase tracking-widest label "CONTACT" in muted gold (#8b7355), large serif heading "Contact us", and one line of body text "We'd love to hear from you. Reach us by email or fill in the form below." in light gray. Right half: a placeholder for an image that fills the full height. Mobile: stacks vertically, image on top.
    
    Part 2 — Contact Cards Grid 3-column grid below the hero (2-col tablet, 1-col mobile). Cream background (#f5f0e8). Each card has: a thin-line SVG icon, a bold label, and body text. Thin top border on each card. 40px padding inside each card. Cards are editable via theme block settings.
    
    Card 1 — Icon: envelope SVG | Label: "Email Us" | Body: "info@nectarandcomb.in" Card 2 — Icon: instagram SVG | Label: "Follow us on Instagram" | Body: "@nectarandcomb.in" Card 3 — Icon: map pin SVG | Label: "Our Address" | Body: "Plot No. 101, Sector-82, JLPL Industrial Area, SAS Nagar, Mohali, Punjab — 140308"
    
    Overall style: serif headings, generous whitespace, muted earth tones, no buttons or arrow links, understated luxury feel.
    
    Also add an option to add link to link instagram 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-layout-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-contact-hero-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    min-height: {{ block.settings.hero_min_height }}px;
  }

  .ai-contact-hero__content-{{ ai_gen_id }} {
    background-color: {{ block.settings.hero_bg_color }};
    padding: {{ block.settings.hero_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-contact-hero__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.label_tracking }}px;
    color: {{ block.settings.label_color }};
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
    margin: 0;
  }

  .ai-contact-hero__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    margin: 0;
    line-height: 1.1;
  }

  .ai-contact-hero__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-contact-hero__image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-contact-hero__image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-contact-hero__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e8dcc8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-contact-hero__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-contact-cards-{{ ai_gen_id }} {
    background-color: {{ block.settings.cards_bg_color }};
    padding: {{ block.settings.cards_padding }}px;
  }

  .ai-contact-cards__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.cards_gap }}px;
    max-width: {{ block.settings.cards_max_width }}px;
    margin: 0 auto;
  }

  .ai-contact-card-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    border-top: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_content_gap }}px;
  }

  .ai-contact-card__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-contact-card__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-contact-card__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_label_size }}px;
    font-weight: {{ block.settings.card_label_weight }};
    color: {{ block.settings.card_label_color }};
    margin: 0;
  }

  .ai-contact-card__body-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_body_size }}px;
    color: {{ block.settings.card_body_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-contact-card__body-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-contact-card__body-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 989px) {
    .ai-contact-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-contact-hero-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-contact-hero__image-{{ ai_gen_id }} {
      order: -1;
      min-height: 300px;
    }

    .ai-contact-hero__content-{{ ai_gen_id }} {
      padding: {{ block.settings.hero_padding | times: 0.6 }}px;
    }

    .ai-contact-hero__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-contact-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-contact-cards-{{ ai_gen_id }} {
      padding: {{ block.settings.cards_padding | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-contact-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-hero-{{ ai_gen_id }}">
    <div class="ai-contact-hero__content-{{ ai_gen_id }}">
      {% if block.settings.hero_label != blank %}
        <div class="ai-contact-hero__label-{{ ai_gen_id }}">{{ block.settings.hero_label }}</div>
      {% endif %}
      
      {% if block.settings.hero_heading != blank %}
        <h1 class="ai-contact-hero__heading-{{ ai_gen_id }}">{{ block.settings.hero_heading }}</h1>
      {% endif %}
      
      {% if block.settings.hero_text != blank %}
        <p class="ai-contact-hero__text-{{ ai_gen_id }}">{{ block.settings.hero_text }}</p>
      {% endif %}
    </div>

    <div class="ai-contact-hero__image-{{ ai_gen_id }}">
      {% if block.settings.hero_image %}
        <img
          src="{{ block.settings.hero_image | image_url: width: 1200 }}"
          alt="{{ block.settings.hero_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.hero_image.width }}"
          height="{{ block.settings.hero_image.height }}"
        >
      {% else %}
        <div class="ai-contact-hero__image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-contact-cards-{{ ai_gen_id }}">
    <div class="ai-contact-cards__grid-{{ ai_gen_id }}">
      <div class="ai-contact-card-{{ ai_gen_id }}">
        <div class="ai-contact-card__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m2 7 10 6 10-6" />
          </svg>
        </div>
        <h3 class="ai-contact-card__label-{{ ai_gen_id }}">{{ block.settings.card_1_label }}</h3>
        <div class="ai-contact-card__body-{{ ai_gen_id }}">
          {% if block.settings.card_1_link %}
            <a href="mailto:{{ block.settings.card_1_body }}">{{ block.settings.card_1_body }}</a>
          {% else %}
            {{ block.settings.card_1_body }}
          {% endif %}
        </div>
      </div>

      <div class="ai-contact-card-{{ ai_gen_id }}">
        <div class="ai-contact-card__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <path d="M17.5 6.5h.01" />
          </svg>
        </div>
        <h3 class="ai-contact-card__label-{{ ai_gen_id }}">{{ block.settings.card_2_label }}</h3>
        <div class="ai-contact-card__body-{{ ai_gen_id }}">
          {% if block.settings.card_2_link != blank %}
            <a href="{{ block.settings.card_2_link }}" target="_blank" rel="noopener">{{ block.settings.card_2_body }}</a>
          {% else %}
            {{ block.settings.card_2_body }}
          {% endif %}
        </div>
      </div>

      <div class="ai-contact-card-{{ ai_gen_id }}">
        <div class="ai-contact-card__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
        </div>
        <h3 class="ai-contact-card__label-{{ ai_gen_id }}">{{ block.settings.card_3_label }}</h3>
        <div class="ai-contact-card__body-{{ ai_gen_id }}">{{ block.settings.card_3_body }}</div>
      </div>
    </div>
  </div>
</div>

