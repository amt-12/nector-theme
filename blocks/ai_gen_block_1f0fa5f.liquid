<script>
  (function() {
    class ProductAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.panels = this.querySelectorAll('.ai-product-accordion__panel-{{ ai_gen_id }}');
        this.footnote = this.querySelector('.ai-product-accordion__footnote-{{ ai_gen_id }}');
        this.setupEventListeners();
        this.checkFootnoteVisibility();
      }

      setupEventListeners() {
        this.panels.forEach((panel) => {
          const header = panel.querySelector('.ai-product-accordion__header-{{ ai_gen_id }}');
          
          header.addEventListener('click', () => {
            const isActive = panel.classList.contains('active');
            
            if (isActive) {
              panel.classList.remove('active');
              header.setAttribute('aria-expanded', 'false');
            } else {
              panel.classList.add('active');
              header.setAttribute('aria-expanded', 'true');
            }

            this.checkFootnoteVisibility();
          });
        });
      }

      checkFootnoteVisibility() {
        const purityPanel = this.querySelector('[data-panel="3"]');
        
        if (purityPanel && purityPanel.classList.contains('active')) {
          this.footnote.classList.add('visible');
        } else {
          this.footnote.classList.remove('visible');
        }
      }
    }

    customElements.define('product-accordion-{{ ai_gen_id }}', ProductAccordion{{ ai_gen_id }});
  })();
</script>

