{% doc %}
  @prompt
    Create a product page block called "Product Accordion" for a premium honey brand. Display three collapsible accordion panels: Panel 1 — "Description" with a rich text / textarea setting for product description content, open by default. Panel 2 — "Flavour Profile" with 4 parameters (Sweetness, Floral Notes, Texture, Aftertaste), each with a label text field and a 0–5 range slider displayed as a thin filled progress bar, closed by default. Panel 3 — "Purity Parameters" with 5 parameters (Moisture %, Colour Grade, Texture, Crystallisation, Purity Score), each with a label text field and a 0–100 range slider displayed as a thin filled progress bar, closed by default. Panel 4 — "Why is my honey crystallised" with a rich text / textarea setting for description content.  Panel 5 — "Our Beekeepers" with a rich text / textarea setting for description content. Panel 6 — "Shipping & Delivery" with a rich text / textarea setting for description content. Each panel has a heading text field, a chevron/arrow icon that rotates on open/close, smooth expand/collapse animation. Add a small italic footnote below all panels (configurable text, default "Parameters reflect our sourcing standards and intake checks for every batch.") — shown only when Purity Parameters panel is open. Style: warm honey tones, muted, editorial, premium — no bright colors. Clean thin divider lines between panels. Thin top border divider above the whole block. Works inside a product page template. Mobile-first layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-accordion-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    border-top: 1px solid {{ block.settings.divider_color }};
    padding-top: 24px;
  }

  .ai-product-accordion__panel-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-product-accordion__header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    cursor: pointer;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
  }

  .ai-product-accordion__header-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-product-accordion__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 500;
    color: {{ block.settings.heading_color }};
    margin: 0;
    letter-spacing: 0.02em;
  }

  .ai-product-accordion__icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 16px;
  }

  .ai-product-accordion__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    stroke-width: 1.5;
  }

  .ai-product-accordion__panel-{{ ai_gen_id }}.active .ai-product-accordion__icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-product-accordion__content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
  }

  .ai-product-accordion__panel-{{ ai_gen_id }}.active .ai-product-accordion__content-{{ ai_gen_id }} {
    max-height: 2000px;
    padding-bottom: 24px;
  }

  .ai-product-accordion__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-product-accordion__parameter-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-product-accordion__parameter-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-product-accordion__parameter-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .ai-product-accordion__parameter-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.parameter_label_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 400;
  }

  .ai-product-accordion__parameter-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.parameter_label_size }}px;
    color: {{ block.settings.parameter_value_color }};
    font-weight: 500;
  }

  .ai-product-accordion__progress-bar-{{ ai_gen_id }} {
    width: 100%;
    height: 4px;
    background-color: {{ block.settings.progress_bg_color }};
    border-radius: 2px;
    overflow: hidden;
  }

  .ai-product-accordion__progress-fill-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.progress_fill_color }};
    transition: width 0.6s ease;
    border-radius: 2px;
  }

  .ai-product-accordion__footnote-{{ ai_gen_id }} {
    font-size: {{ block.settings.footnote_size }}px;
    font-style: italic;
    color: {{ block.settings.footnote_color }};
    margin-top: 24px;
    line-height: 1.5;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.3s ease, max-height 0.3s ease, margin-top 0.3s ease;
  }

  .ai-product-accordion__footnote-{{ ai_gen_id }}.visible {
    opacity: 1;
    max-height: 200px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-accordion-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-product-accordion__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-product-accordion__header-{{ ai_gen_id }} {
      padding: 16px 0;
    }
  }
{% endstyle %}

