      "label": "Heading text",
      "default": "Nothing is added. Nothing is removed."
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "serif"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
