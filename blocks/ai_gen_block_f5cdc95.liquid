{% doc %}
  @prompt
    Create a full-width cinematic image section for an About Us page. 100vw full bleed, no container constraints. The section has two parts stacked vertically: Top part: full-width dark moody background image (honey dripping on honeycomb). Small all-caps label "CHAPTER 3" in top-left corner in white/muted color. Centered over the image in large white serif font: "Nothing is added. Nothing is removed." Image height approximately 60-70vh. Bottom part: a narrow cream/off-white strip below the image with small centered body text: "Our cold extraction method involves gently spinning the honey from the comb without the use of heat. This preserves the raw, unadulterated quality of the honey, maintaining its nutritional value and distinct flavor profile." Premium, editorial, minimalist aesthetic. No buttons.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cinematic-section-{{ ai_gen_id }} {
    display: block;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  .ai-cinematic-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.image_height }}vh;
    overflow: hidden;
  }

  .ai-cinematic-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-cinematic-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-cinematic-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-cinematic-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    pointer-events: none;
  }

  .ai-cinematic-label-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.label_top_spacing }}px;
    left: {{ block.settings.label_left_spacing }}px;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_font_size }}px;
    letter-spacing: {{ block.settings.label_letter_spacing }}px;
    text-transform: uppercase;
    font-weight: 400;
    z-index: 2;
  }

  .ai-cinematic-heading-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
    text-align: center;
    max-width: 90%;
    z-index: 2;
    margin: 0;
    line-height: 1.2;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
  }

  .ai-cinematic-text-strip-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.strip_background_color }};
    padding: {{ block.settings.strip_padding_vertical }}px {{ block.settings.strip_padding_horizontal }}px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-cinematic-text-content-{{ ai_gen_id }} {
    color: {{ block.settings.strip_text_color }};
    font-size: {{ block.settings.strip_font_size }}px;
    line-height: 1.6;
    text-align: center;
    max-width: {{ block.settings.strip_max_width }}px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-cinematic-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}vh;
    }

    .ai-cinematic-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }

    .ai-cinematic-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_font_size_mobile }}px;
      top: {{ block.settings.label_top_spacing_mobile }}px;
      left: {{ block.settings.label_left_spacing_mobile }}px;
    }

    .ai-cinematic-text-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.strip_font_size_mobile }}px;
    }

    .ai-cinematic-text-strip-{{ ai_gen_id }} {
      padding: {{ block.settings.strip_padding_vertical_mobile }}px {{ block.settings.strip_padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-cinematic-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cinematic-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        srcset="{{ block.settings.background_image | image_url: width: 800 }} 800w,
                {{ block.settings.background_image | image_url: width: 1200 }} 1200w,
                {{ block.settings.background_image | image_url: width: 1600 }} 1600w,
                {{ block.settings.background_image | image_url: width: 2000 }} 2000w,
                {{ block.settings.background_image | image_url: width: 2400 }} 2400w"
        sizes="100vw"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-cinematic-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-cinematic-image-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}

    <div class="ai-cinematic-overlay-{{ ai_gen_id }}"></div>

    {% if block.settings.label_text != blank %}
      <div class="ai-cinematic-label-{{ ai_gen_id }}">
        {{ block.settings.label_text }}
      </div>
    {% endif %}

    {% if block.settings.heading_text != blank %}
      <h2 class="ai-cinematic-heading-{{ ai_gen_id }}">
        {{ block.settings.heading_text }}
      </h2>
    {% endif %}
  </div>

  {% if block.settings.strip_text != blank %}
    <div class="ai-cinematic-text-strip-{{ ai_gen_id }}">
      <p class="ai-cinematic-text-content-{{ ai_gen_id }}">
        {{ block.settings.strip_text }}
      </p>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Cinematic image section",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
