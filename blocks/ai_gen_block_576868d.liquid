{% doc %}
  @prompt
    Rebuild a footer layout as a proper 3-column grid where all three column headings sit on the exact same horizontal baseline. First column: "Contact Us" heading, multi-line address, email line, and a small sub-line text "*Nectar & Comb is a brand by Farmure — a nature-first company." Second column: "Our Hive" heading with links (About Us, Jars, Snap-Click Sachets, The Nectar Edit, Recipes). Third column: "Learn More" heading with links (FAQs, How We Try to Do This Right, Contact Us, Returns & Refund Policy, Terms & Conditions, Privacy Policy). Use CSS grid with equal columns and align-items: flex-start so all columns top-align perfectly. All text fields and links should be editable from the theme editor sidebar.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-footer-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
    align-items: flex-start;
  }

  .ai-footer-grid__column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-footer-grid__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
  }

  .ai-footer-grid__text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-footer-grid__link-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    line-height: 1.6;
    transition: color 0.2s ease;
  }

  .ai-footer-grid__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-footer-grid__subtext-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-footer-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_column_gap }}px;
    }
  }
{% endstyle %}

<div class="ai-footer-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-grid__container-{{ ai_gen_id }}">
    <div class="ai-footer-grid__column-{{ ai_gen_id }}">
      {% if block.settings.column_1_heading != blank %}
        <h3 class="ai-footer-grid__heading-{{ ai_gen_id }}">{{ block.settings.column_1_heading }}</h3>
      {% endif %}
      {% if block.settings.column_1_address != blank %}
        <div class="ai-footer-grid__text-{{ ai_gen_id }}">{{ block.settings.column_1_address }}</div>
      {% endif %}
      {% if block.settings.column_1_email != blank %}
        <a href="mailto:{{ block.settings.column_1_email }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_1_email }}</a>
      {% endif %}
      {% if block.settings.column_1_subtext != blank %}
        <p class="ai-footer-grid__subtext-{{ ai_gen_id }}">{{ block.settings.column_1_subtext }}</p>
      {% endif %}
    </div>

    <div class="ai-footer-grid__column-{{ ai_gen_id }}">
      {% if block.settings.column_2_heading != blank %}
        <h3 class="ai-footer-grid__heading-{{ ai_gen_id }}">{{ block.settings.column_2_heading }}</h3>
      {% endif %}
      {% if block.settings.column_2_link_1_text != blank %}
        <a href="{{ block.settings.column_2_link_1_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_2_link_1_text }}</a>
      {% endif %}
      {% if block.settings.column_2_link_2_text != blank %}
        <a href="{{ block.settings.column_2_link_2_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_2_link_2_text }}</a>
      {% endif %}
      {% if block.settings.column_2_link_3_text != blank %}
        <a href="{{ block.settings.column_2_link_3_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_2_link_3_text }}</a>
      {% endif %}
      {% if block.settings.column_2_link_4_text != blank %}
        <a href="{{ block.settings.column_2_link_4_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_2_link_4_text }}</a>
      {% endif %}
      {% if block.settings.column_2_link_5_text != blank %}
        <a href="{{ block.settings.column_2_link_5_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_2_link_5_text }}</a>
      {% endif %}
    </div>

    <div class="ai-footer-grid__column-{{ ai_gen_id }}">
      {% if block.settings.column_3_heading != blank %}
        <h3 class="ai-footer-grid__heading-{{ ai_gen_id }}">{{ block.settings.column_3_heading }}</h3>
      {% endif %}
      {% if block.settings.column_3_link_1_text != blank %}
        <a href="{{ block.settings.column_3_link_1_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_3_link_1_text }}</a>
      {% endif %}
      {% if block.settings.column_3_link_2_text != blank %}
        <a href="{{ block.settings.column_3_link_2_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_3_link_2_text }}</a>
      {% endif %}
      {% if block.settings.column_3_link_3_text != blank %}
        <a href="{{ block.settings.column_3_link_3_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_3_link_3_text }}</a>
      {% endif %}
      {% if block.settings.column_3_link_4_text != blank %}
        <a href="{{ block.settings.column_3_link_4_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_3_link_4_text }}</a>
      {% endif %}
      {% if block.settings.column_3_link_5_text != blank %}
        <a href="{{ block.settings.column_3_link_5_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_3_link_5_text }}</a>
      {% endif %}
      {% if block.settings.column_3_link_6_text != blank %}
        <a href="{{ block.settings.column_3_link_6_url }}" class="ai-footer-grid__link-{{ ai_gen_id }}">{{ block.settings.column_3_link_6_text }}</a>
      {% endif %}
    </div>
  </div>
</div>

