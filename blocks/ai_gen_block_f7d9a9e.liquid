      "type": "font_picker",
      "id": "quote_font",
      "label": "Font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Font size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "quote_line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.3
    },
    {
      "type": "range",
      "id": "quote_margin",
      "label": "Bottom margin",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Divider"
