      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Body text"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Single-origin. Cold-extracted. Fully traceable. From hive to jar without compromise."
