{% doc %}
  @prompt
    Create a single Liquid theme section called "Philosophy" for a premium honey brand. It must be FULL PAGE WIDTH with no max-width container — the section should stretch 100vw edge to edge.
    
    Layout: Two equal columns side by side:
    - LEFT column: dark/black background, a large full-height editorial product image (image picker setting), object-fit: cover
    - RIGHT column: cream/off-white background (#F5F0E8), centered content with generous padding:
      - Small uppercase tracking label at top (e.g. "SECTION 1 — PHILOSOPHY"), configurable text field
      - Large serif blockquote in dark text: ‘We believe honey should be treated with the same reverence as wine.’ — configurable text field
      - Thin divider line
      - Smaller body paragraph: "Single-origin. Cold-extracted. Fully traceable. From hive to jar without compromise." — configurable text field
    
    The section height should be at least 80vh. No outer wrapper max-width. Full bleed edge to edge. Luxury minimalist aesthetic. All text and image customizable via theme editor settings.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-philosophy-section-{{ ai_gen_id }} {
    display: block;
    width: 100vw;
    min-height: 80vh;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  .ai-philosophy-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
    width: 100%;
  }

  .ai-philosophy-image-column-{{ ai_gen_id }} {
    background-color: {{ block.settings.image_bg_color }};
    position: relative;
    overflow: hidden;
  }

  .ai-philosophy-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-philosophy-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.image_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-philosophy-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-philosophy-content-column-{{ ai_gen_id }} {
    background-color: {{ block.settings.content_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-philosophy-content-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-philosophy-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    letter-spacing: {{ block.settings.label_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.text_color }};
    margin-bottom: {{ block.settings.label_margin }}px;
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
  }

  .ai-philosophy-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    line-height: {{ block.settings.quote_line_height }};
    color: {{ block.settings.text_color }};
    margin-bottom: {{ block.settings.quote_margin }}px;
    font-family: {{ block.settings.quote_font.family }}, {{ block.settings.quote_font.fallback_families }};
    font-weight: {{ block.settings.quote_font.weight }};
  }

  .ai-philosophy-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.text_color }};
    margin: {{ block.settings.divider_margin }}px 0;
  }

  .ai-philosophy-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-philosophy-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ai-philosophy-image-column-{{ ai_gen_id }} {
      min-height: 50vh;
    }

    .ai-philosophy-content-column-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.6 }}px;
    }

    .ai-philosophy-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.9 }}px;
    }

    .ai-philosophy-quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_size | times: 0.7 }}px;
    }

    .ai-philosophy-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<philosophy-section-{{ ai_gen_id }}
  class="ai-philosophy-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-philosophy-container-{{ ai_gen_id }}">
    <div class="ai-philosophy-image-column-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-philosophy-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-philosophy-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-philosophy-content-column-{{ ai_gen_id }}">
      <div class="ai-philosophy-content-wrapper-{{ ai_gen_id }}">
        {% if block.settings.label != blank %}
          <div class="ai-philosophy-label-{{ ai_gen_id }}">
            {{ block.settings.label }}
          </div>
        {% endif %}

        {% if block.settings.quote != blank %}
          <blockquote class="ai-philosophy-quote-{{ ai_gen_id }}">
            {{ block.settings.quote }}
          </blockquote>
        {% endif %}

        {% if block.settings.show_divider %}
          <div class="ai-philosophy-divider-{{ ai_gen_id }}"></div>
        {% endif %}

        {% if block.settings.body != blank %}
          <div class="ai-philosophy-body-{{ ai_gen_id }}">
            {{ block.settings.body }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</philosophy-section-{{ ai_gen_id }}>

<script>
  (function() {
    class PhilosophySection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('philosophy-section-{{ ai_gen_id }}', PhilosophySection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Philosophy",
  "tag": null,
