{% doc %}
  @prompt
    Create two custom Liquid theme sections that match a premium editorial honey brand aesthetic:
    
    **SECTION 1 — PHILOSOPHY**
    A full-width split two-column layout on a dark/black background:
    - Left column: a large editorial product image (dark moody photography style)
    - Right column: cream/off-white background with:
      - A small uppercase label at the top (configurable section label)
      - A large serif quote in dark text: ‘We believe honey should be treated with the same reverence as wine.’
      - A smaller body text below: "Single-origin. Cold-extracted. Fully traceable. From hive to jar without compromise."
    - All text and image customizable via theme editor settings
    - Minimal, luxury editorial feel
    
    **SECTION 2 — PRODUCT SHOWCASE**
    A product collection showcase on a cream/off-white background (#F5F0E8):
    - Section label at top: "SECTION 2 — PRODUCT SHOWCASE"
    - Heading: "The Collection" in large serif font
    - Subheading: "Four honeys. Four origins. All cold-extracted."
    - Two-column layout:
      - LEFT (large): Featured product — large image, product name in large uppercase serif, origin/region text, price, and italic tagline below
      - RIGHT (smaller): 3 stacked product cards, each with: small square image, product name in uppercase, origin/region, price aligned right, italic tagline. Separated by thin dividers.
    - All products and text configurable via theme editor settings (product pickers, text fields)
    - Cream background, dark text, minimal borders
    
    Both sections should use clean HTML/CSS with no external dependencies, match a luxury minimalist aesthetic, and be fully customizable in the Shopify theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-showcase-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-showcase-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-showcase-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_margin }}px;
  }

  .ai-showcase-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    letter-spacing: {{ block.settings.label_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.label_color }};
    margin-bottom: {{ block.settings.label_margin }}px;
    font-weight: 400;
  }

  .ai-showcase-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin-bottom: {{ block.settings.heading_margin }}px;
  }

  .ai-showcase-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    line-height: {{ block.settings.subheading_line_height }};
    color: {{ block.settings.subheading_color }};
  }

  .ai-showcase-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_margin_top }}px;
  }

  .ai-showcase-featured-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-showcase-featured-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.featured_aspect_ratio }};
    margin-bottom: {{ block.settings.featured_image_margin }}px;
    overflow: hidden;
  }

  .ai-showcase-featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-showcase-featured-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e8dcc8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-showcase-featured-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-showcase-featured-name-{{ ai_gen_id }} {
    font-family: {{ block.settings.product_name_font.family }}, {{ block.settings.product_name_font.fallback_families }};
    font-weight: {{ block.settings.product_name_font.weight }};
    font-style: {{ block.settings.product_name_font.style }};
    font-size: {{ block.settings.featured_name_size }}px;
    letter-spacing: {{ block.settings.featured_name_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.product_name_color }};
    margin-bottom: {{ block.settings.featured_name_margin }}px;
  }

  .ai-showcase-featured-origin-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_origin_size }}px;
    color: {{ block.settings.origin_color }};
    margin-bottom: {{ block.settings.featured_origin_margin }}px;
  }

  .ai-showcase-featured-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_price_size }}px;
    color: {{ block.settings.price_color }};
    margin-bottom: {{ block.settings.featured_price_margin }}px;
  }

  .ai-showcase-featured-tagline-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_tagline_size }}px;
    font-style: italic;
    color: {{ block.settings.tagline_color }};
    line-height: 1.5;
  }

  .ai-showcase-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-showcase-product-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.list_image_size }}px 1fr;
    gap: {{ block.settings.list_gap }}px;
    padding: {{ block.settings.list_item_padding }}px 0;
    border-bottom: {{ block.settings.divider_width }}px solid {{ block.settings.divider_color }};
  }

  .ai-showcase-product-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-showcase-product-image-{{ ai_gen_id }} {
    width: {{ block.settings.list_image_size }}px;
    height: {{ block.settings.list_image_size }}px;
    overflow: hidden;
  }

  .ai-showcase-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-showcase-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e8dcc8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-showcase-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-showcase-product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-showcase-product-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: {{ block.settings.list_name_margin }}px;
  }

  .ai-showcase-product-name-{{ ai_gen_id }} {
    font-family: {{ block.settings.product_name_font.family }}, {{ block.settings.product_name_font.fallback_families }};
    font-weight: {{ block.settings.product_name_font.weight }};
    font-style: {{ block.settings.product_name_font.style }};
    font-size: {{ block.settings.list_name_size }}px;
    letter-spacing: {{ block.settings.list_name_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.product_name_color }};
  }

  .ai-showcase-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.list_price_size }}px;
    color: {{ block.settings.price_color }};
    white-space: nowrap;
  }

  .ai-showcase-product-origin-{{ ai_gen_id }} {
    font-size: {{ block.settings.list_origin_size }}px;
    color: {{ block.settings.origin_color }};
    margin-bottom: {{ block.settings.list_origin_margin }}px;
  }

  .ai-showcase-product-tagline-{{ ai_gen_id }} {
    font-size: {{ block.settings.list_tagline_size }}px;
    font-style: italic;
    color: {{ block.settings.tagline_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-showcase-section-{{ ai_gen_id }} {
      padding: 60px 20px;
    }

    .ai-showcase-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 50px;
    }

    .ai-showcase-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-showcase-featured-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_name_size | times: 0.7 }}px;
    }

    .ai-showcase-product-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.list_image_size | times: 0.8 }}px 1fr;
    }

    .ai-showcase-product-image-{{ ai_gen_id }} {
      width: {{ block.settings.list_image_size | times: 0.8 }}px;
      height: {{ block.settings.list_image_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-showcase-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-showcase-container-{{ ai_gen_id }}">
    <div class="ai-showcase-header-{{ ai_gen_id }}">
      {% if block.settings.label != blank %}
        <div class="ai-showcase-label-{{ ai_gen_id }}">
          {{ block.settings.label }}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-showcase-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-showcase-subheading-{{ ai_gen_id }}">
          {{ block.settings.subheading }}
        </div>
      {% endif %}
    </div>

    <div class="ai-showcase-grid-{{ ai_gen_id }}">
      <div class="ai-showcase-featured-{{ ai_gen_id }}">
        <div class="ai-showcase-featured-image-{{ ai_gen_id }}">
          {% if block.settings.featured_product and block.settings.featured_product.featured_image %}
            <img
              src="{{ block.settings.featured_product.featured_image | image_url: width: 800 }}"
              alt="{{ block.settings.featured_product.featured_image.alt | escape }}"
              loading="lazy"
              width="800"
              height="800"
            >
          {% else %}
            <div class="ai-showcase-featured-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        {% if block.settings.featured_product %}
          <div class="ai-showcase-featured-name-{{ ai_gen_id }}">
            {{ block.settings.featured_product.title }}
          </div>

          {% if block.settings.featured_origin != blank %}
            <div class="ai-showcase-featured-origin-{{ ai_gen_id }}">
              {{ block.settings.featured_origin }}
            </div>
          {% endif %}

          <div class="ai-showcase-featured-price-{{ ai_gen_id }}">
            {{ block.settings.featured_product.price | money }}
          </div>

          {% if block.settings.featured_tagline != blank %}
            <div class="ai-showcase-featured-tagline-{{ ai_gen_id }}">
              {{ block.settings.featured_tagline }}
            </div>
          {% endif %}
        {% else %}
          <div class="ai-showcase-featured-name-{{ ai_gen_id }}">
            FEATURED PRODUCT
          </div>
          <div class="ai-showcase-featured-origin-{{ ai_gen_id }}">
            Select a product
          </div>
        {% endif %}
      </div>

      <div class="ai-showcase-list-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign origin_key = 'product_' | append: i | append: '_origin'
            assign tagline_key = 'product_' | append: i | append: '_tagline'

            assign product = block.settings[product_key]
            assign origin = block.settings[origin_key]
            assign tagline = block.settings[tagline_key]
          %}

          <div class="ai-showcase-product-{{ ai_gen_id }}">
            <div class="ai-showcase-product-image-{{ ai_gen_id }}">
              {% if product and product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 200 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-showcase-product-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-showcase-product-info-{{ ai_gen_id }}">
              {% if product %}
                <div class="ai-showcase-product-header-{{ ai_gen_id }}">
                  <div class="ai-showcase-product-name-{{ ai_gen_id }}">
                    {{ product.title }}
                  </div>
                  <div class="ai-showcase-product-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </div>
                </div>

                {% if origin != blank %}
                  <div class="ai-showcase-product-origin-{{ ai_gen_id }}">
                    {{ origin }}
                  </div>
                {% endif %}

                {% if tagline != blank %}
                  <div class="ai-showcase-product-tagline-{{ ai_gen_id }}">
                    {{ tagline }}
                  </div>
                {% endif %}
              {% else %}
                <div class="ai-showcase-product-header-{{ ai_gen_id }}">
                  <div class="ai-showcase-product-name-{{ ai_gen_id }}">
                    PRODUCT {{ i }}
                  </div>
                </div>
                <div class="ai-showcase-product-origin-{{ ai_gen_id }}">
                  Select a product
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

