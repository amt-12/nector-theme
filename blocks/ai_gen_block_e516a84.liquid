<script>
  (function() {
    class ProductAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.headers = this.querySelectorAll('.ai-product-accordion__header-{{ ai_gen_id }}');
        this.purityPanel = this.querySelector('[data-panel="panel-3"]');
        this.footnote = this.querySelector('[data-footnote]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.headers.forEach((header) => {
          header.addEventListener('click', () => {
            const panelId = header.getAttribute('data-panel');
            const content = this.querySelector(`[data-content="${panelId}"]`);
            const isExpanded = header.getAttribute('aria-expanded') === 'true';

            if (isExpanded) {
              header.setAttribute('aria-expanded', 'false');
              content.classList.remove('active');
            } else {
              header.setAttribute('aria-expanded', 'true');
              content.classList.add('active');
            }

            if (this.footnote && panelId === 'panel-3') {
              if (!isExpanded) {
                this.footnote.classList.add('visible');
              } else {
                this.footnote.classList.remove('visible');
              }
            }
          });
        });
      }
    }

    customElements.define('product-accordion-{{ ai_gen_id }}', ProductAccordion{{ ai_gen_id }});
  })();
</script>

