{% doc %}
  @prompt
    Create a new accordion block that matches the existing "Product accordion"
    AI-generated block style on this product page. It should have 6 rows with the following content:
    Create a product page block called "Product Accordion" for a premium honey brand. Display three collapsible accordion panels: Panel 1 — "Description" with a rich text / textarea setting for product description content. Panel 2 — "Flavour Profile" with 4 parameters (Sweetness, Floral Notes, Texture, Aftertaste), each with a label text field and a 0–5 range slider displayed as a thin filled progress bar, closed by default. Panel 3 — "Purity Parameters" with 5 parameters (Moisture %, Colour Grade, Texture, Crystallisation, Purity Score), each with a label text field and a 0–100 range slider displayed as a thin filled progress bar, closed by default. Panel 4 — "Why is my honey crystallised" with a rich text / textarea setting for description content.  Panel 5 — "Our Beekeepers" with a rich text / textarea setting for description content. Panel 6 — "Shipping & Delivery" with a rich text / textarea setting for description content. Each panel has a heading text field, a chevron/arrow icon that rotates on open/close, smooth expand/collapse animation. Add a small italic footnote below all panels (configurable text, default "Parameters reflect our sourcing standards and intake checks for every batch.") — shown only when Purity Parameters panel is open. Style: warm honey tones, muted, editorial, premium — no bright colors. Clean thin divider lines between panels. Thin top border divider above the whole block. Works inside a product page template. Mobile-first layout.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-accordion-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-product-accordion__panel-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-product-accordion__header-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.panel_padding }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .ai-product-accordion__header-{{ ai_gen_id }}:hover {
    color: {{ block.settings.heading_hover_color }};
  }

  .ai-product-accordion__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-left: 16px;
    transition: transform 0.3s ease;
  }

  .ai-product-accordion__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .ai-product-accordion__header-{{ ai_gen_id }}[aria-expanded="true"] .ai-product-accordion__icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-product-accordion__content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  .ai-product-accordion__content-{{ ai_gen_id }}.active {
    max-height: 2000px;
  }

  .ai-product-accordion__body-{{ ai_gen_id }} {
    padding-bottom: {{ block.settings.panel_padding }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-product-accordion__body-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-product-accordion__body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-product-accordion__parameter-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-product-accordion__parameter-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-product-accordion__parameter-label-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
    font-size: {{ block.settings.parameter_label_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-accordion__parameter-value-{{ ai_gen_id }} {
    font-weight: 500;
    color: {{ block.settings.heading_color }};
  }

  .ai-product-accordion__progress-bar-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.progress_bar_height }}px;
    background-color: {{ block.settings.progress_bg_color }};
    border-radius: {{ block.settings.progress_bar_height | divided_by: 2 }}px;
    overflow: hidden;
  }

  .ai-product-accordion__progress-fill-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.progress_fill_color }};
    transition: width 0.6s ease;
  }

  .ai-product-accordion__footnote-{{ ai_gen_id }} {
    margin-top: 16px;
    padding-top: 12px;
    font-size: {{ block.settings.footnote_size }}px;
    font-style: italic;
    color: {{ block.settings.footnote_color }};
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.3s ease, max-height 0.3s ease;
  }

  .ai-product-accordion__footnote-{{ ai_gen_id }}.visible {
    opacity: 1;
    max-height: 100px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-accordion__header-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-product-accordion__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.95 }}px;
    }

    .ai-product-accordion__parameter-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.parameter_label_size | times: 0.95 }}px;
    }
  }
{% endstyle %}

