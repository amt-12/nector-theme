{% doc %}
  @prompt
    Create a standalone sustainability/commitments page section for a premium honey brand called NECTAR&COMB. The section should have:
    
    1. A centered hero area with:
       - Heading: "How We Try to Do This Right"
       - Subheading: "We're a small brand. What we have is a set of commitments."
       - A thin gold/amber decorative divider line under the heading
    
    2. A vertically stacked list of 5 commitment blocks, each with:
       - A small gold/amber horizontal rule above the title
       - An all-caps spaced letter heading
       - A short centered paragraph description
       - Generous whitespace between blocks
    
    The 5 commitments are:
    - MINIMAL INPUTS: "We believe in letting nature do the work. Our beekeeping practices prioritize the health of the hive, avoiding unnecessary interventions and chemicals to maintain the purity of the honey."
    - COLD EXTRACTION ONLY: "Our honey is never heated or pasteurized. We use a gentle cold extraction process to preserve all the natural enzymes, pollen, and distinct flavors of the comb."
    - GLASS PACKAGING: "We are committed to reducing plastic waste. All our honey is packaged in reusable and recyclable glass jars, ensuring freshness and sustainability."
    - DIRECT SOURCING: "We build strong, direct relationships with local artisan beekeepers. This ensures fair compensation and transparency in every step of the journey from hive to jar."
    - FSSAI CERTIFIED: "Our commitment to quality is backed by rigorous standards. We are fully FSSAI certified, guaranteeing that our honey meets the highest food safety and quality regulations."
    
    3. A closing italic line at the bottom: "We're not perfect. We're working on it."
    
    Design style: editorial, luxury, warm cream/off-white background (#F5F0E8 or similar), serif fonts for headings, clean sans-serif for body text, gold/amber accent color (#C8922A or similar). All text centered. Section should be fully customizable via theme editor settings (heading, subheading, each commitment title and description, accent color, background color).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sustainability-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-sustainability-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-sustainability-hero-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.hero_spacing }}px;
  }

  .ai-sustainability-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-sustainability-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.accent_color }};
    margin: 0 auto {{ block.settings.divider_spacing }}px;
  }

  .ai-sustainability-subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-sustainability-commitments-{{ ai_gen_id }} {
    margin-top: {{ block.settings.commitments_top_spacing }}px;
  }

  .ai-sustainability-commitment-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.commitment_spacing }}px;
  }

  .ai-sustainability-commitment-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-sustainability-commitment-rule-{{ ai_gen_id }} {
    width: {{ block.settings.rule_width }}px;
    height: {{ block.settings.rule_height }}px;
    background-color: {{ block.settings.accent_color }};
    margin: 0 auto {{ block.settings.rule_spacing }}px;
  }

  .ai-sustainability-commitment-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.commitment_title_size }}px;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    margin: 0 0 {{ block.settings.title_spacing }}px;
  }

  .ai-sustainability-commitment-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.7;
    color: {{ block.settings.text_color }};
    margin: 0;
    max-width: {{ block.settings.description_max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-sustainability-closing-{{ ai_gen_id }} {
    margin-top: {{ block.settings.closing_top_spacing }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: italic;
    font-size: {{ block.settings.closing_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    opacity: {{ block.settings.closing_opacity }};
  }

  @media screen and (max-width: 749px) {
    .ai-sustainability-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-sustainability-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-sustainability-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-sustainability-commitment-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.commitment_title_size | times: 0.9 }}px;
    }

    .ai-sustainability-commitment-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-sustainability-closing-{{ ai_gen_id }} {
      font-size: {{ block.settings.closing_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-sustainability-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sustainability-container-{{ ai_gen_id }}">
    <div class="ai-sustainability-hero-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-sustainability-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}
      
      <div class="ai-sustainability-divider-{{ ai_gen_id }}"></div>
      
      {% if block.settings.subheading != blank %}
        <p class="ai-sustainability-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ai-sustainability-commitments-{{ ai_gen_id }}">
      {% if block.settings.show_commitment_1 %}
        <div class="ai-sustainability-commitment-{{ ai_gen_id }}">
          <div class="ai-sustainability-commitment-rule-{{ ai_gen_id }}"></div>
          {% if block.settings.commitment_1_title != blank %}
            <h2 class="ai-sustainability-commitment-title-{{ ai_gen_id }}">{{ block.settings.commitment_1_title }}</h2>
          {% endif %}
          {% if block.settings.commitment_1_description != blank %}
            <p class="ai-sustainability-commitment-description-{{ ai_gen_id }}">{{ block.settings.commitment_1_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_commitment_2 %}
        <div class="ai-sustainability-commitment-{{ ai_gen_id }}">
          <div class="ai-sustainability-commitment-rule-{{ ai_gen_id }}"></div>
          {% if block.settings.commitment_2_title != blank %}
            <h2 class="ai-sustainability-commitment-title-{{ ai_gen_id }}">{{ block.settings.commitment_2_title }}</h2>
          {% endif %}
          {% if block.settings.commitment_2_description != blank %}
            <p class="ai-sustainability-commitment-description-{{ ai_gen_id }}">{{ block.settings.commitment_2_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_commitment_3 %}
        <div class="ai-sustainability-commitment-{{ ai_gen_id }}">
          <div class="ai-sustainability-commitment-rule-{{ ai_gen_id }}"></div>
          {% if block.settings.commitment_3_title != blank %}
            <h2 class="ai-sustainability-commitment-title-{{ ai_gen_id }}">{{ block.settings.commitment_3_title }}</h2>
          {% endif %}
          {% if block.settings.commitment_3_description != blank %}
            <p class="ai-sustainability-commitment-description-{{ ai_gen_id }}">{{ block.settings.commitment_3_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_commitment_4 %}
        <div class="ai-sustainability-commitment-{{ ai_gen_id }}">
          <div class="ai-sustainability-commitment-rule-{{ ai_gen_id }}"></div>
          {% if block.settings.commitment_4_title != blank %}
            <h2 class="ai-sustainability-commitment-title-{{ ai_gen_id }}">{{ block.settings.commitment_4_title }}</h2>
          {% endif %}
          {% if block.settings.commitment_4_description != blank %}
            <p class="ai-sustainability-commitment-description-{{ ai_gen_id }}">{{ block.settings.commitment_4_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_commitment_5 %}
        <div class="ai-sustainability-commitment-{{ ai_gen_id }}">
          <div class="ai-sustainability-commitment-rule-{{ ai_gen_id }}"></div>
          {% if block.settings.commitment_5_title != blank %}
            <h2 class="ai-sustainability-commitment-title-{{ ai_gen_id }}">{{ block.settings.commitment_5_title }}</h2>
          {% endif %}
          {% if block.settings.commitment_5_description != blank %}
            <p class="ai-sustainability-commitment-description-{{ ai_gen_id }}">{{ block.settings.commitment_5_description }}</p>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if block.settings.closing_text != blank %}
      <p class="ai-sustainability-closing-{{ ai_gen_id }}">{{ block.settings.closing_text }}</p>
    {% endif %}
  </div>
</div>

