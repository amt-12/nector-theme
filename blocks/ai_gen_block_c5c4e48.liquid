{% doc %}
  @prompt
    Create a "From the Journal" blog section that exactly matches this layout: a centered heading "From the Journal" and a centered subheading "Recipes, origin notes, and the quiet art of eating well." below it. Then an asymmetric two-column grid: the LEFT column takes up about 55% width and shows ONE large featured article card — full bleed image with the article title and date/read-time text overlaid at the bottom-left in white, on a dark overlay. The RIGHT column takes up 45% and shows TWO stacked article cards of equal height — each with a full bleed image on top and the article title, date, and read-time as plain text BELOW the image (not overlaid), on a light/white background. Below the entire grid, a subtle "View all posts →" text link in a muted accent color (e.g. warm amber/gold), left-aligned or centered. Warm off-white section background. Clean, minimal, editorial typography — no borders, no shadows, no cards with rounded corners. Blog source, heading, subheading, and "View all posts" link should all be configurable in the theme editor., from the journel block should be full page width , lets regenerate this with you giving me options to select which recipe i want here on the home page and how many , give me an option to change the size of the sidebar articles cards 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-journal-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_background }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-journal-container-{{ ai_gen_id }} {
    width: 100%;
    padding: 0 20px;
  }

  .ai-journal-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-journal-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .ai-journal-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    font-weight: 400;
    line-height: 1.5;
  }

  .ai-journal-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 55% 45%;
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.link_spacing }}px;
  }

  .ai-journal-featured-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .ai-journal-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-journal-featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e8dcc8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-journal-featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .ai-journal-featured-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}), transparent);
    padding: 40px 30px;
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-journal-featured-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_title_size }}px;
    margin: 0 0 8px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .ai-journal-featured-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    opacity: 0.9;
    font-weight: 300;
  }

  .ai-journal-sidebar-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-journal-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .ai-journal-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ block.settings.sidebar_card_aspect_ratio }};
    margin-bottom: 16px;
  }

  .ai-journal-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-journal-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #e8dcc8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-journal-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .ai-journal-card-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: 0;
  }

  .ai-journal-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 8px;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .ai-journal-card-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.card_meta_color }};
    font-weight: 300;
  }

  .ai-journal-link-{{ ai_gen_id }} {
    text-align: {{ block.settings.link_alignment }};
  }

  .ai-journal-link-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_size }}px;
    font-weight: 400;
    letter-spacing: 0.02em;
    transition: opacity 0.2s ease;
  }

  .ai-journal-link-{{ ai_gen_id }} a:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 989px) {
    .ai-journal-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-journal-featured-{{ ai_gen_id }} {
      aspect-ratio: 4 / 3;
    }

    .ai-journal-sidebar-{{ ai_gen_id }} {
      gap: 30px;
    }

    .ai-journal-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-journal-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-journal-featured-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_title_size | times: 0.8 }}px;
    }

    .ai-journal-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<from-the-journal-{{ ai_gen_id }} class="ai-journal-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-journal-container-{{ ai_gen_id }}">
    <div class="ai-journal-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-journal-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-journal-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    {% assign featured_article = block.settings.featured_article %}
    {% assign sidebar_count = block.settings.sidebar_article_count %}

    <div class="ai-journal-grid-{{ ai_gen_id }}">
      <div class="ai-journal-featured-{{ ai_gen_id }}">
        {% if featured_article %}
          <a href="{{ featured_article.url }}" style="display: block; height: 100%; text-decoration: none; color: inherit;">
            {% if featured_article.image %}
              <img
                src="{{ featured_article.image | image_url: width: 1200 }}"
                alt="{{ featured_article.image.alt | escape }}"
                class="ai-journal-featured-image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ featured_article.image.width }}"
                height="{{ featured_article.image.height }}"
              >
            {% else %}
              <div class="ai-journal-featured-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            <div class="ai-journal-featured-overlay-{{ ai_gen_id }}">
              <h3 class="ai-journal-featured-title-{{ ai_gen_id }}">{{ featured_article.title }}</h3>
              <div class="ai-journal-featured-meta-{{ ai_gen_id }}">
                {{ featured_article.published_at | date: '%B %d, %Y' }}
                {% if featured_article.content != blank %}
                  {% assign word_count = featured_article.content | strip_html | split: ' ' | size %}
                  {% assign read_time = word_count | divided_by: 200 | at_least: 1 %}
                  · {{ read_time }} min read
                {% endif %}
              </div>
            </div>
          </a>
        {% else %}
          <div class="ai-journal-featured-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
          <div class="ai-journal-featured-overlay-{{ ai_gen_id }}">
            <h3 class="ai-journal-featured-title-{{ ai_gen_id }}">Featured article title</h3>
            <div class="ai-journal-featured-meta-{{ ai_gen_id }}">Date · Read time</div>
          </div>
        {% endif %}
      </div>

      <div class="ai-journal-sidebar-{{ ai_gen_id }}">
        {% if sidebar_count >= 1 and block.settings.sidebar_article_1 %}
          {% assign article = block.settings.sidebar_article_1 %}
          <a href="{{ article.url }}" class="ai-journal-card-{{ ai_gen_id }}">
            <div class="ai-journal-card-image-wrapper-{{ ai_gen_id }}">
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt | escape }}"
                  class="ai-journal-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                >
              {% else %}
                <div class="ai-journal-card-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-journal-card-content-{{ ai_gen_id }}">
              <h4 class="ai-journal-card-title-{{ ai_gen_id }}">{{ article.title }}</h4>
              <div class="ai-journal-card-meta-{{ ai_gen_id }}">
                {{ article.published_at | date: '%B %d, %Y' }}
                {% if article.content != blank %}
                  {% assign word_count = article.content | strip_html | split: ' ' | size %}
                  {% assign read_time = word_count | divided_by: 200 | at_least: 1 %}
                  · {{ read_time }} min read
                {% endif %}
              </div>
            </div>
          </a>
        {% elsif sidebar_count >= 1 %}
          <div class="ai-journal-card-{{ ai_gen_id }}">
            <div class="ai-journal-card-image-wrapper-{{ ai_gen_id }}">
              <div class="ai-journal-card-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="ai-journal-card-content-{{ ai_gen_id }}">
              <h4 class="ai-journal-card-title-{{ ai_gen_id }}">Article title</h4>
              <div class="ai-journal-card-meta-{{ ai_gen_id }}">Date · Read time</div>
            </div>
          </div>
        {% endif %}

        {% if sidebar_count >= 2 and block.settings.sidebar_article_2 %}
          {% assign article = block.settings.sidebar_article_2 %}
          <a href="{{ article.url }}" class="ai-journal-card-{{ ai_gen_id }}">
            <div class="ai-journal-card-image-wrapper-{{ ai_gen_id }}">
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt | escape }}"
                  class="ai-journal-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                >
              {% else %}
                <div class="ai-journal-card-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-journal-card-content-{{ ai_gen_id }}">
              <h4 class="ai-journal-card-title-{{ ai_gen_id }}">{{ article.title }}</h4>
              <div class="ai-journal-card-meta-{{ ai_gen_id }}">
                {{ article.published_at | date: '%B %d, %Y' }}
                {% if article.content != blank %}
                  {% assign word_count = article.content | strip_html | split: ' ' | size %}
                  {% assign read_time = word_count | divided_by: 200 | at_least: 1 %}
                  · {{ read_time }} min read
                {% endif %}
              </div>
            </div>
          </a>
        {% elsif sidebar_count >= 2 %}
          <div class="ai-journal-card-{{ ai_gen_id }}">
            <div class="ai-journal-card-image-wrapper-{{ ai_gen_id }}">
              <div class="ai-journal-card-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="ai-journal-card-content-{{ ai_gen_id }}">
              <h4 class="ai-journal-card-title-{{ ai_gen_id }}">Article title</h4>
              <div class="ai-journal-card-meta-{{ ai_gen_id }}">Date · Read time</div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {% if block.settings.view_all_text != blank and block.settings.view_all_link != blank %}
      <div class="ai-journal-link-{{ ai_gen_id }}">
        <a href="{{ block.settings.view_all_link }}">{{ block.settings.view_all_text }}</a>
      </div>
    {% endif %}
  </div>
</from-the-journal-{{ ai_gen_id }}>

<script>
  (function() {
    class FromTheJournal{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('from-the-journal-{{ ai_gen_id }}', FromTheJournal{{ ai_gen_id }});
  })();
</script>

{% schema %}
