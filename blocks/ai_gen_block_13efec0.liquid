{% doc %}
  @prompt
    Regenerate the Product Showcase block for a luxury honey brand homepage. The block has two parts: left side shows a featured product with a large image, right side shows a vertical list of 3 products each with a small thumbnail image. Include these specific settings: (1) a range slider to control the featured product image size/width as a percentage (30% to 100%), (2) a range slider to control the list product thumbnail image size in pixels (60px to 200px), (3) section label text, heading text, subheading text, (4) featured product picker with tagline field, (5) three product pickers each with a tagline field, (6) grid gap slider, max width slider, top/bottom padding sliders, horizontal padding slider, (7) color pickers for background, heading, subheading, product name, price, tagline, divider, (8) font size controls for heading, subheading, featured product name, list product name. Design must be clean, editorial, ultra-luxury — Cormorant serif for all headings and product names, subtle horizontal dividers between list items, prices displayed inline next to product names, generous whitespace throughout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-product-showcase-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-product-showcase-header-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-product-showcase-label-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.subheading_color }};
    margin-bottom: 12px;
  }

  .ai-product-showcase-heading-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .ai-product-showcase-subheading-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.subheading_font_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-product-showcase-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.featured_image_width }}% 1fr;
    gap: {{ block.settings.grid_gap }}px;
    align-items: start;
  }

  .ai-product-showcase-featured-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-product-showcase-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-showcase-featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-product-showcase-featured-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-showcase-featured-name-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.featured_product_name_font_size }}px;
    color: {{ block.settings.product_name_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-product-showcase-featured-price-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.featured_product_name_font_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-showcase-featured-tagline-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.tagline_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-product-showcase-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.list_thumbnail_size }}px 1fr;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
    align-items: center;
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }}:first-child {
    padding-top: 0;
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-product-showcase-list-image-{{ ai_gen_id }} {
    width: {{ block.settings.list_thumbnail_size }}px;
    height: {{ block.settings.list_thumbnail_size }}px;
    flex-shrink: 0;
  }

  .ai-product-showcase-list-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-showcase-list-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-showcase-list-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-showcase-list-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ai-product-showcase-list-name-price-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-product-showcase-list-name-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.list_product_name_font_size }}px;
    color: {{ block.settings.product_name_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-product-showcase-list-price-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.list_product_name_font_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-showcase-list-tagline-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.tagline_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-product-showcase-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-product-showcase-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_font_size }}px * 0.7);
    }

    .ai-product-showcase-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_font_size }}px * 0.85);
    }

    .ai-product-showcase-featured-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.featured_product_name_font_size }}px * 0.8);
    }

    .ai-product-showcase-featured-price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.featured_product_name_font_size }}px * 0.8);
    }

    .ai-product-showcase-list-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.list_product_name_font_size }}px * 0.85);
    }

    .ai-product-showcase-list-price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.list_product_name_font_size }}px * 0.85);
    }

    .ai-product-showcase-list-item-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.list_thumbnail_size | times: 0.8 }}px 1fr;
      gap: 16px;
      padding: 20px 0;
    }

    .ai-product-showcase-list-image-{{ ai_gen_id }} {
      width: {{ block.settings.list_thumbnail_size | times: 0.8 }}px;
      height: {{ block.settings.list_thumbnail_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-product-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-showcase-container-{{ ai_gen_id }}">
    {% if block.settings.label != blank or block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-product-showcase-header-{{ ai_gen_id }}">
        {% if block.settings.label != blank %}
          <div class="ai-product-showcase-label-{{ ai_gen_id }}">{{ block.settings.label }}</div>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h2 class="ai-product-showcase-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-product-showcase-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-product-showcase-grid-{{ ai_gen_id }}">
      <div class="ai-product-showcase-featured-{{ ai_gen_id }}">
        {% if block.settings.featured_product %}
          <a href="{{ block.settings.featured_product.url }}" class="ai-product-showcase-featured-image-{{ ai_gen_id }}">
            {% if block.settings.featured_product.featured_image %}
              <img
                src="{{ block.settings.featured_product.featured_image | image_url: width: 1200 }}"
                alt="{{ block.settings.featured_product.featured_image.alt | escape }}"
                width="{{ block.settings.featured_product.featured_image.width }}"
                height="{{ block.settings.featured_product.featured_image.height }}"
                loading="lazy"
              >
            {% else %}
              <div class="ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </a>
          <div class="ai-product-showcase-featured-info-{{ ai_gen_id }}">
            <h3 class="ai-product-showcase-featured-name-{{ ai_gen_id }}">
              <a href="{{ block.settings.featured_product.url }}" style="text-decoration: none; color: inherit;">
                {{ block.settings.featured_product.title }}
              </a>
            </h3>
            <div class="ai-product-showcase-featured-price-{{ ai_gen_id }}">
              {{ block.settings.featured_product.price | money }}
            </div>
            {% if block.settings.featured_tagline != blank %}
              <p class="ai-product-showcase-featured-tagline-{{ ai_gen_id }}">{{ block.settings.featured_tagline }}</p>
            {% endif %}
          </div>
        {% else %}
          <div class="ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
          <div class="ai-product-showcase-featured-info-{{ ai_gen_id }}">
            <h3 class="ai-product-showcase-featured-name-{{ ai_gen_id }}">Featured product</h3>
            <div class="ai-product-showcase-featured-price-{{ ai_gen_id }}">₹0.00</div>
          </div>
        {% endif %}
      </div>

      <div class="ai-product-showcase-list-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign product_key = 'list_product_' | append: i
            assign tagline_key = 'list_tagline_' | append: i
            assign product = block.settings[product_key]
            assign tagline = block.settings[tagline_key]
          %}

          <div class="ai-product-showcase-list-item-{{ ai_gen_id }}">
            <div class="ai-product-showcase-list-image-{{ ai_gen_id }}">
              {% if product %}
                <a href="{{ product.url }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 400 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                      loading="lazy"
                    >
                  {% else %}
                    <div class="ai-product-showcase-list-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </a>
              {% else %}
                <div class="ai-product-showcase-list-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-product-showcase-list-info-{{ ai_gen_id }}">
              <div class="ai-product-showcase-list-name-price-{{ ai_gen_id }}">
                {% if product %}
                  <h4 class="ai-product-showcase-list-name-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" style="text-decoration: none; color: inherit;">
                      {{ product.title }}
                    </a>
                  </h4>
                  <div class="ai-product-showcase-list-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </div>
                {% else %}
                  <h4 class="ai-product-showcase-list-name-{{ ai_gen_id }}">Product {{ i }}</h4>
                  <div class="ai-product-showcase-list-price-{{ ai_gen_id }}">₹0.00</div>
                {% endif %}
              </div>
              {% if tagline != blank %}
                <p class="ai-product-showcase-list-tagline-{{ ai_gen_id }}">{{ tagline }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product showcase",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Selection"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our finest honey varieties, handpicked for their exceptional quality and unique flavor profiles."
    },
    {
      "type": "header",
      "content": "Featured product"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Product"
    },
    {
      "type": "textarea",
      "id": "featured_tagline",
      "label": "Tagline"
    },
    {
      "type": "header",
      "content": "List products"
    },
    {
      "type": "product",
      "id": "list_product_1",
      "label": "Product 1"
    },
    {
      "type": "textarea",
      "id": "list_tagline_1",
      "label": "Tagline 1"
    },
    {
      "type": "product",
      "id": "list_product_2",
      "label": "Product 2"
    },
    {
      "type": "textarea",
      "id": "list_tagline_2",
      "label": "Tagline 2"
    },
    {
      "type": "product",
      "id": "list_product_3",
      "label": "Product 3"
    },
    {
      "type": "textarea",
      "id": "list_tagline_3",
      "label": "Tagline 3"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "featured_image_width",
      "label": "Featured product width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "list_thumbnail_size",
      "label": "List thumbnail size",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fafaf5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "product_name_color",
      "label": "Product name",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Tagline",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider",
      "default": "#e8dcc8"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Subheading size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "featured_product_name_font_size",
      "label": "Featured product name size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "list_product_name_font_size",
      "label": "List product name size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Product showcase"
    }
  ]
}
{% endschema %}
