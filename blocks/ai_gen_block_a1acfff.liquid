{% doc %}
  @prompt
    Regenerate the Product Showcase block for a luxury honey brand homepage. The block has two parts: left side shows a featured product with a large image, right side shows a vertical list of 3 products each with a small thumbnail image. Include these specific settings: (1) a range slider to control the featured product image size/width as a percentage (30% to 100%), (2) a range slider to control the list product thumbnail image size in pixels (60px to 200px), (3) section label text, heading text, subheading text, (4) featured product picker with tagline field, (5) three product pickers each with a tagline field, (6) grid gap slider, max width slider, top/bottom padding sliders, horizontal padding slider, (7) color pickers for background, heading, subheading, product name, price, tagline, divider, (8) font size controls for heading, subheading, featured product name, list product name, (9) a "View All" button at the bottom center of the section — with a text field (default: "View All"), a URL/link field, a button style selector (solid or outline), and a toggle to show/hide the button. Design must be clean, editorial, ultra-luxury — Cormorant serif for all headings and product names, subtle horizontal dividers between list items, prices displayed inline next to product names, generous whitespace throughout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-product-showcase-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-product-showcase-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-product-showcase-label-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.subheading_color }};
    margin-bottom: 12px;
  }

  .ai-product-showcase-heading-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-product-showcase-subheading-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.subheading_font_size }}px;
    color: {{ block.settings.subheading_color }};
    margin-top: 16px;
    line-height: 1.5;
  }

  .ai-product-showcase-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    align-items: start;
  }

  .ai-product-showcase-featured-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-product-showcase-featured-image-{{ ai_gen_id }} {
    width: {{ block.settings.featured_image_width }}%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .ai-product-showcase-featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-product-showcase-featured-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-showcase-featured-name-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.featured_product_name_font_size }}px;
    color: {{ block.settings.product_name_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-product-showcase-featured-price-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.featured_product_name_font_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-showcase-featured-tagline-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 16px;
    color: {{ block.settings.tagline_color }};
    font-style: italic;
    margin-top: 4px;
  }

  .ai-product-showcase-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
    text-decoration: none;
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }}:first-child {
    padding-top: 0;
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-product-showcase-list-image-{{ ai_gen_id }} {
    width: {{ block.settings.list_thumbnail_size }}px;
    height: {{ block.settings.list_thumbnail_size }}px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .ai-product-showcase-list-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-showcase-list-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-showcase-list-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-showcase-list-info-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-product-showcase-list-name-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.list_product_name_font_size }}px;
    color: {{ block.settings.product_name_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-product-showcase-list-price-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.list_product_name_font_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-showcase-list-tagline-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 14px;
    color: {{ block.settings.tagline_color }};
    font-style: italic;
    margin-top: 2px;
  }

  .ai-product-showcase-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  .ai-product-showcase-button-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 18px;
    padding: 14px 40px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s ease;
  }

  .ai-product-showcase-button-solid-{{ ai_gen_id }} {
    background-color: {{ block.settings.heading_color }};
    color: {{ block.settings.background_color }};
    border: 1px solid {{ block.settings.heading_color }};
  }

  .ai-product-showcase-button-solid-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.heading_color }};
  }

  .ai-product-showcase-button-outline-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.heading_color }};
    border: 1px solid {{ block.settings.heading_color }};
  }

  .ai-product-showcase-button-outline-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.heading_color }};
    color: {{ block.settings.background_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-showcase-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-product-showcase-featured-image-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-product-showcase-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_font_size }}px * 0.7);
    }

    .ai-product-showcase-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_font_size }}px * 0.85);
    }
  }
{% endstyle %}

<product-showcase-{{ ai_gen_id }} class="ai-product-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-showcase-container-{{ ai_gen_id }}">
    {% if block.settings.section_label != blank or block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-product-showcase-header-{{ ai_gen_id }}">
        {% if block.settings.section_label != blank %}
          <div class="ai-product-showcase-label-{{ ai_gen_id }}">{{ block.settings.section_label }}</div>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h2 class="ai-product-showcase-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-product-showcase-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-product-showcase-grid-{{ ai_gen_id }}">
      <div class="ai-product-showcase-featured-{{ ai_gen_id }}">
        {% if block.settings.featured_product != blank %}
          <div class="ai-product-showcase-featured-image-{{ ai_gen_id }}">
            {% if block.settings.featured_product.featured_image %}
              <img
                src="{{ block.settings.featured_product.featured_image | image_url: width: 1200 }}"
                alt="{{ block.settings.featured_product.featured_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.featured_product.featured_image.width }}"
                height="{{ block.settings.featured_product.featured_image.height }}"
              >
            {% else %}
              <div class="ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-product-showcase-featured-info-{{ ai_gen_id }}">
            <h3 class="ai-product-showcase-featured-name-{{ ai_gen_id }}">{{ block.settings.featured_product.title }}</h3>
            <div class="ai-product-showcase-featured-price-{{ ai_gen_id }}">{{ block.settings.featured_product.price | money }}</div>
            {% if block.settings.featured_tagline != blank %}
              <div class="ai-product-showcase-featured-tagline-{{ ai_gen_id }}">{{ block.settings.featured_tagline }}</div>
            {% endif %}
          </div>
        {% else %}
          <div class="ai-product-showcase-featured-image-{{ ai_gen_id }}">
            <div class="ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          </div>
          <div class="ai-product-showcase-featured-info-{{ ai_gen_id }}">
            <h3 class="ai-product-showcase-featured-name-{{ ai_gen_id }}">Featured Product</h3>
            <div class="ai-product-showcase-featured-price-{{ ai_gen_id }}">₹0.00</div>
          </div>
        {% endif %}
      </div>

      <div class="ai-product-showcase-list-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign product_key = 'list_product_' | append: i
            assign tagline_key = 'list_tagline_' | append: i
            assign product = block.settings[product_key]
            assign tagline = block.settings[tagline_key]
          %}

          {% if product != blank %}
            <a href="{{ product.url }}" class="ai-product-showcase-list-item-{{ ai_gen_id }}">
              <div class="ai-product-showcase-list-image-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                  >
                {% else %}
                  <div class="ai-product-showcase-list-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-product-showcase-list-info-{{ ai_gen_id }}">
                <h4 class="ai-product-showcase-list-name-{{ ai_gen_id }}">{{ product.title }}</h4>
                <div class="ai-product-showcase-list-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                {% if tagline != blank %}
                  <div class="ai-product-showcase-list-tagline-{{ ai_gen_id }}">{{ tagline }}</div>
                {% endif %}
              </div>
            </a>
          {% else %}
            <div class="ai-product-showcase-list-item-{{ ai_gen_id }}">
              <div class="ai-product-showcase-list-image-{{ ai_gen_id }}">
                <div class="ai-product-showcase-list-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              </div>
              <div class="ai-product-showcase-list-info-{{ ai_gen_id }}">
                <h4 class="ai-product-showcase-list-name-{{ ai_gen_id }}">Product {{ i }}</h4>
                <div class="ai-product-showcase-list-price-{{ ai_gen_id }}">₹0.00</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if block.settings.show_button %}
      <div class="ai-product-showcase-button-wrapper-{{ ai_gen_id }}">
        <a
          href="{{ block.settings.button_link }}"
          class="ai-product-showcase-button-{{ ai_gen_id }} {% if block.settings.button_style == 'solid' %}ai-product-showcase-button-solid-{{ ai_gen_id }}{% else %}ai-product-showcase-button-outline-{{ ai_gen_id }}{% endif %}"
        >
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</product-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.loadCormorantFont();
      }

      loadCormorantFont() {
        if (!document.querySelector('link[href*="Cormorant"]')) {
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = 'https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,600;1,400&display=swap';
          document.head.appendChild(link);
        }
      }
    }

    customElements.define('product-showcase-{{ ai_gen_id }}', ProductShowcase{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
