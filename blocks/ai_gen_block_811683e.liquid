{% doc %}
  @prompt
    Create a compact editorial article card grid block for a luxury honey brand journal page. Each card should have: thumbnail image (180px height, object-fit cover), article tag + read time in small caps muted text above the title, serif title, one-line excerpt below in muted color. Cards in a 3-column grid on desktop, 2 on tablet, 1 on mobile. Compact padding, no borders, subtle hover effect. Cream background #f5f0e8, dark brown #1c1812 text, premium editorial luxury aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-article-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-article-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-article-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ai-article-card-{{ ai_gen_id }}:hover {
    opacity: {{ block.settings.hover_opacity }};
  }

  .ai-article-card__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    overflow: hidden;
    margin-bottom: {{ block.settings.content_spacing }}px;
  }

  .ai-article-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-article-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-article-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-article-card__meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: {{ block.settings.content_spacing }}px;
    font-size: {{ block.settings.meta_font_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: {{ block.settings.meta_color }};
    font-family: {{ block.settings.meta_font.family }}, {{ block.settings.meta_font.fallback_families }};
    font-weight: {{ block.settings.meta_font.weight }};
  }

  .ai-article-card__meta-separator-{{ ai_gen_id }} {
    width: 3px;
    height: 3px;
    background-color: {{ block.settings.meta_color }};
    border-radius: 50%;
    opacity: 0.5;
  }

  .ai-article-card__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_font_size }}px;
    line-height: 1.3;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.content_spacing }}px 0;
  }

  .ai-article-card__excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_font_size }}px;
    line-height: 1.5;
    color: {{ block.settings.excerpt_color }};
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  @media screen and (max-width: 989px) {
    .ai-article-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-article-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<article-grid-{{ ai_gen_id }} class="ai-article-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-article-grid__container-{{ ai_gen_id }}">
    {% if block.settings.blog != blank %}
      {% for article in block.settings.blog.articles limit: block.settings.articles_to_show %}
        <a href="{{ article.url }}" class="ai-article-card-{{ ai_gen_id }}">
          <div class="ai-article-card__image-wrapper-{{ ai_gen_id }}">
            {% if article.image %}
              <img
                src="{{ article.image | image_url: width: 600 }}"
                alt="{{ article.image.alt | escape }}"
                loading="lazy"
                width="600"
                height="{{ block.settings.image_height }}"
                class="ai-article-card__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-article-card__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-article-card__meta-{{ ai_gen_id }}">
            {% if article.tags.size > 0 %}
              <span>{{ article.tags.first }}</span>
            {% else %}
              <span>Journal</span>
            {% endif %}
            <span class="ai-article-card__meta-separator-{{ ai_gen_id }}"></span>
            <span>{{ block.settings.read_time_text }}</span>
          </div>

          <h3 class="ai-article-card__title-{{ ai_gen_id }}">
            {{ article.title }}
          </h3>

          {% if article.excerpt != blank %}
            <p class="ai-article-card__excerpt-{{ ai_gen_id }}">
              {{ article.excerpt | strip_html | truncate: 120 }}
            </p>
          {% endif %}
        </a>
      {% endfor %}
    {% else %}
      {% for i in (1..3) %}
        <div class="ai-article-card-{{ ai_gen_id }}">
          <div class="ai-article-card__image-wrapper-{{ ai_gen_id }}">
            <div class="ai-article-card__image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>

          <div class="ai-article-card__meta-{{ ai_gen_id }}">
            <span>Journal</span>
            <span class="ai-article-card__meta-separator-{{ ai_gen_id }}"></span>
            <span>{{ block.settings.read_time_text }}</span>
          </div>

          <h3 class="ai-article-card__title-{{ ai_gen_id }}">
            Article title
          </h3>

          <p class="ai-article-card__excerpt-{{ ai_gen_id }}">
            A brief excerpt from the article will appear here.
          </p>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</article-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ArticleGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('article-grid-{{ ai_gen_id }}', ArticleGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Article card grid",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "label": "Articles to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "read_time_text",
      "label": "Read time text",
      "default": "5 min read"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 12,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Content spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 120,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 180
    },
    {
      "type": "color",
      "id": "placeholder_bg",
      "label": "Placeholder background",
      "default": "#e8dcc8"
    },
    {
      "type": "header",
      "content": "Meta text"
    },
    {
      "type": "font_picker",
      "id": "meta_font",
      "label": "Font",
      "default": "instrument_sans_n4"
    },
    {
      "type": "range",
      "id": "meta_font_size",
      "label": "Font size",
      "min": 9,
      "max": 14,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Color",
      "default": "#6b5a48"
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Font",
      "default": "cormorant_n4"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Font size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#1c1812"
    },
    {
      "type": "header",
      "content": "Excerpt"
    },
    {
      "type": "range",
      "id": "excerpt_font_size",
      "label": "Font size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "excerpt_color",
      "label": "Color",
      "default": "#6b5a48"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f0e8"
    },
    {
      "type": "range",
      "id": "hover_opacity",
      "label": "Hover opacity",
      "min": 0.5,
      "max": 1,
      "step": 0.1,
      "default": 0.7
    }
  ],
  "presets": [
    {
      "name": "Article card grid"
    }
  ]
}
{% endschema %}
