{% doc %}
  @prompt
    Create a full-width hero banner section that spans 100% of the viewport width with no container constraints, max-width, or side margins. Use width:100vw and ensure the section wrapper itself breaks out of any parent container. It should include: a large editorial headline (default: "10 grams of ritual."), a subtext paragraph (default: "The Snap-Click Sachet. Precision-portioned. Entirely intentional."), a price line (default: "From ₹299"), and a minimal outlined CTA button (default label: "Shop Sachets") that links to a collection. All text centered and overlaid on a dark background image. Aesthetic: premium, dark, editorial — restrained typography, no heavy gradients. All fields (headline, subtext, price, button label, button link, background image) customizable in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    min-height: {{ block.settings.min_height_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-banner-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-banner-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.fallback_background_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-banner-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-hero-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-hero-banner-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    color: {{ block.settings.text_color }};
    padding: 40px 20px;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-hero-banner-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size_desktop }}px;
    line-height: 1.1;
    margin: 0 0 {{ block.settings.spacing_below_headline }}px;
    font-weight: {{ block.settings.headline_weight }};
    letter-spacing: {{ block.settings.headline_letter_spacing }}em;
  }

  .ai-hero-banner-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size_desktop }}px;
    line-height: 1.5;
    margin: 0 0 {{ block.settings.spacing_below_subtext }}px;
    font-weight: {{ block.settings.subtext_weight }};
    opacity: {{ block.settings.subtext_opacity | divided_by: 100.0 }};
  }

  .ai-hero-banner-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size_desktop }}px;
    margin: 0 0 {{ block.settings.spacing_below_price }}px;
    font-weight: {{ block.settings.price_weight }};
    letter-spacing: {{ block.settings.price_letter_spacing }}em;
  }

  .ai-hero-banner-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    letter-spacing: {{ block.settings.button_letter_spacing }}em;
    transition: all 0.3s ease;
  }

  .ai-hero-banner-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-hero-banner-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
    }

    .ai-hero-banner-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size_mobile }}px;
    }

    .ai-hero-banner-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-banner-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-banner-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-banner-content-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-banner-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-hero-banner-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    {% if block.settings.price_text != blank %}
      <div class="ai-hero-banner-price-{{ ai_gen_id }}">{{ block.settings.price_text }}</div>
    {% endif %}

    {% if block.settings.button_label != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-hero-banner-cta-{{ ai_gen_id }}">
        {{ block.settings.button_label }}
      </a>
    {% endif %}
  </div>
</div>

