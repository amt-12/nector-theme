{% doc %}
  @prompt
    Create a full-width Chapter/Vision/Mission block for an About Us page. Content: small caps label "CHAPTER 4", then subheading "OUR VISION", then large heading "A world where purity is the default, not the premium.", then a thin vertical divider line, then subheading "OUR MISSION", then large heading "To make India's finest single-origin honey accessible to anyone who refuses to settle." Style: full-width section with no side margins or container constraints, premium editorial, minimal, centered text, warm off-white #FAFAF5 background, serif fonts, generous vertical padding.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vision-mission-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-vision-mission-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
    padding: 0 20px;
  }

  .ai-vision-mission-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    letter-spacing: {{ block.settings.label_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.label_color }};
    margin: 0 0 {{ block.settings.label_margin }}px;
    font-weight: 400;
  }

  .ai-vision-mission-section-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-vision-mission-section-{{ ai_gen_id }}:last-of-type {
    margin-bottom: 0;
  }

  .ai-vision-mission-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    letter-spacing: {{ block.settings.subheading_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 {{ block.settings.subheading_margin }}px;
    font-weight: 500;
  }

  .ai-vision-mission-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 400;
  }

  .ai-vision-mission-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_margin }}px auto;
  }

  @media screen and (max-width: 749px) {
    .ai-vision-mission-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-vision-mission-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size_mobile }}px;
      margin-bottom: {{ block.settings.label_margin_mobile }}px;
    }

    .ai-vision-mission-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
      margin-bottom: {{ block.settings.subheading_margin_mobile }}px;
    }

    .ai-vision-mission-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-vision-mission-section-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.section_spacing_mobile }}px;
    }

    .ai-vision-mission-divider-{{ ai_gen_id }} {
      margin: {{ block.settings.divider_margin_mobile }}px auto;
    }
  }
{% endstyle %}

<div class="ai-vision-mission-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-vision-mission-content-{{ ai_gen_id }}">
    {% if block.settings.chapter_label != blank %}
      <div class="ai-vision-mission-label-{{ ai_gen_id }}">
        {{ block.settings.chapter_label }}
      </div>
    {% endif %}

    {% if block.settings.vision_subheading != blank or block.settings.vision_heading != blank %}
      <div class="ai-vision-mission-section-{{ ai_gen_id }}">
        {% if block.settings.vision_subheading != blank %}
          <div class="ai-vision-mission-subheading-{{ ai_gen_id }}">
            {{ block.settings.vision_subheading }}
          </div>
        {% endif %}
        {% if block.settings.vision_heading != blank %}
          <h2 class="ai-vision-mission-heading-{{ ai_gen_id }}">
            {{ block.settings.vision_heading }}
          </h2>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-vision-mission-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.mission_subheading != blank or block.settings.mission_heading != blank %}
      <div class="ai-vision-mission-section-{{ ai_gen_id }}">
        {% if block.settings.mission_subheading != blank %}
          <div class="ai-vision-mission-subheading-{{ ai_gen_id }}">
            {{ block.settings.mission_subheading }}
          </div>
        {% endif %}
        {% if block.settings.mission_heading != blank %}
          <h2 class="ai-vision-mission-heading-{{ ai_gen_id }}">
            {{ block.settings.mission_heading }}
          </h2>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

