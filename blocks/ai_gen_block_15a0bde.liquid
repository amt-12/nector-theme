{% doc %}
  @prompt
    Regenerate "The Journal" block for a Recipes blog page on an ultra-luxury premium honey brand website. The block should:
    - Display a heading/title (e.g. "The Journal") with elegant serif typography
    - NOT include a featured article or "other articles" section
    - Have a clean, minimal editorial layout suitable for a luxury brand
    - Include theme editor settings for: top padding and bottom padding (numeric inputs)
    - Match the premium aesthetic of the rest of the page (earthy tones, restrained design)
    all, origin stories, and recipes filter tab should be like in the image. , no articles should be visible. ander after heading there will be a sub heading 
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-journal-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-journal-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-journal-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 16px;
  }

  .ai-journal-title-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .ai-journal-subheading-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 12px auto 0;
    max-width: 600px;
    line-height: 1.6;
    font-weight: 400;
  }

  .ai-journal-filters-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-top: 48px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    padding-bottom: 0;
  }

  .ai-journal-filter-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 12px 0;
    font-family: var(--font-body-family);
    font-size: {{ block.settings.filter_font_size }}px;
    color: {{ block.settings.filter_color }};
    cursor: pointer;
    position: relative;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 400;
    transition: color 0.3s ease;
  }

  .ai-journal-filter-{{ ai_gen_id }}:hover {
    color: {{ block.settings.filter_hover_color }};
  }

  .ai-journal-filter-{{ ai_gen_id }}.active {
    color: {{ block.settings.filter_active_color }};
  }

  .ai-journal-filter-{{ ai_gen_id }}.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background-color: {{ block.settings.filter_active_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-journal-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.6 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-journal-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-journal-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-journal-filters-{{ ai_gen_id }} {
      gap: 20px;
      margin-top: 32px;
    }

    .ai-journal-filter-{{ ai_gen_id }} {
      font-size: {{ block.settings.filter_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<journal-filter-{{ ai_gen_id }} class="ai-journal-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-journal-container-{{ ai_gen_id }}">
    <div class="ai-journal-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-journal-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      
      {% if block.settings.subheading != blank %}
        <p class="ai-journal-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ai-journal-filters-{{ ai_gen_id }}">
      <button class="ai-journal-filter-{{ ai_gen_id }} active" data-filter="all">
        {{ block.settings.filter_all_label }}
      </button>
      <button class="ai-journal-filter-{{ ai_gen_id }}" data-filter="origin-stories">
        {{ block.settings.filter_origin_label }}
      </button>
      <button class="ai-journal-filter-{{ ai_gen_id }}" data-filter="recipes">
        {{ block.settings.filter_recipes_label }}
      </button>
    </div>
  </div>
</journal-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class JournalFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.filterButtons = this.querySelectorAll('.ai-journal-filter-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.filterButtons.forEach((button) => {
          button.addEventListener('click', () => {
            this.updateActiveButton(button);
          });
        });
      }

      updateActiveButton(activeButton) {
        this.filterButtons.forEach((button) => {
          button.classList.remove('active');
        });
        activeButton.classList.add('active');
      }
    }

    customElements.define('journal-filter-{{ ai_gen_id }}', JournalFilter{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "The Journal",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "The Journal"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our stories, recipes, and the journey behind every jar"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#6b6b6b"
    },
    {
      "type": "header",
      "content": "Filter tabs"
    },
    {
      "type": "inline_richtext",
      "id": "filter_all_label",
      "label": "All filter label",
      "default": "All"
    },
    {
      "type": "inline_richtext",
      "id": "filter_origin_label",
      "label": "Origin stories label",
      "default": "Origin Stories"
    },
    {
      "type": "inline_richtext",
      "id": "filter_recipes_label",
      "label": "Recipes label",
      "default": "Recipes"
    },
    {
      "type": "range",
      "id": "filter_font_size",
      "label": "Filter font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "filter_color",
      "label": "Filter color",
      "default": "#6b6b6b"
    },
    {
      "type": "color",
      "id": "filter_hover_color",
      "label": "Filter hover color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "filter_active_color",
      "label": "Active filter color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e8dcc8"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fafaf5"
    }
  ],
  "presets": [
    {
      "name": "The Journal"
    }
  ]
}
{% endschema %}
