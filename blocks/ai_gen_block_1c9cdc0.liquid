{% doc %}
  @prompt
    Regenerate the "Blog posts grid" block for a Recipes blog page on an ultra-luxury premium honey brand website. Requirements:
    - Display blog posts in a clean, elegant grid layout (2-3 columns) with article image, title, excerpt, date, and read more link
    - Clean, minimal serif typography matching a luxury brand aesthetic
    - Earthy, warm color tones with refined whitespace
    - Theme editor settings MUST include: top_padding (number input, px) and bottom_padding (number input, px) so the merchant can control spacing directly from the editor
    - Settings for number of posts to show and number of columns
    - Hover effects on cards should be subtle and refined, befitting a luxury brand, HEADING AND VIEW ALL BUTTON AND BUTTON TYPE AND TOP RIGHT RIGHT IS MISSING, BUTTON TYPE - LINK SECONDARY IS MISSING 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.top_padding }}px;
    padding-bottom: {{ block.settings.bottom_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-blog-grid-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-blog-grid-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
    gap: 20px;
  }

  .ai-blog-grid-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font }}, serif;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 400;
  }

  .ai-blog-grid-view-all-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: Raleway;
    font-size: 14px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .ai-blog-grid-view-all-primary-{{ ai_gen_id }} {
    color: {{ block.settings.button_primary_text_color }};
    background-color: {{ block.settings.button_primary_background_color }};
    border: {{ block.settings.button_primary_border_width }}px solid {{ block.settings.button_primary_border_color }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
  }

  .ai-blog-grid-view-all-primary-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_primary_hover_text_color }};
    background-color: {{ block.settings.button_primary_hover_background_color }};
    border-color: {{ block.settings.button_primary_hover_border_color }};
  }

  .ai-blog-grid-view-all-secondary-{{ ai_gen_id }} {
    color: {{ block.settings.button_secondary_text_color }};
    background-color: {{ block.settings.button_secondary_background_color }};
    border: {{ block.settings.button_secondary_border_width }}px solid {{ block.settings.button_secondary_border_color }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
  }

  .ai-blog-grid-view-all-secondary-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_secondary_hover_text_color }};
    background-color: {{ block.settings.button_secondary_hover_background_color }};
    border-color: {{ block.settings.button_secondary_hover_border_color }};
  }

  .ai-blog-grid-view-all-link-{{ ai_gen_id }} {
    color: {{ block.settings.button_link_text_color }};
    background-color: transparent;
    border: none;
    padding: 0;
    border-bottom: 1px solid {{ block.settings.button_link_text_color }};
    padding-bottom: 2px;
  }

  .ai-blog-grid-view-all-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_link_hover_text_color }};
    border-bottom-color: {{ block.settings.button_link_hover_text_color }};
  }

  .ai-blog-grid-posts-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin: 0;
  }

  .ai-blog-grid-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background_color }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-blog-grid-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .ai-blog-grid-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: #f5f5e8;
  }

  .ai-blog-grid-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ai-blog-grid-card-{{ ai_gen_id }}:hover .ai-blog-grid-image-{{ ai_gen_id }} {
    transform: scale(1.03);
  }

  .ai-blog-grid-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5e8;
  }

  .ai-blog-grid-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-blog-grid-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .ai-blog-grid-date-{{ ai_gen_id }} {
    font-family: {{ block.settings.date_font }}, serif;
    font-size: {{ block.settings.date_size }}px;
    color: {{ block.settings.date_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .ai-blog-grid-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font }}, serif;
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.3;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-weight: 400;
  }

  .ai-blog-grid-title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-blog-grid-title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.title_hover_color }};
  }

  .ai-blog-grid-excerpt-{{ ai_gen_id }} {
    font-family: {{ block.settings.excerpt_font }}, sans-serif;
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    color: {{ block.settings.excerpt_color }};
    margin: 0 0 20px 0;
    flex-grow: 1;
  }

  .ai-blog-grid-read-more-{{ ai_gen_id }} {
    display: inline-block;
    font-family: {{ block.settings.link_font }}, sans-serif;
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border-bottom: 1px solid {{ block.settings.link_color }};
    padding-bottom: 2px;
    transition: color 0.3s ease, border-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-blog-grid-read-more-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    border-bottom-color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-blog-grid-posts-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.8 }}px;
    }

    .ai-blog-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-blog-grid-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-blog-grid-{{ ai_gen_id }} {
      padding-top: {{ block.settings.top_padding | times: 0.7 }}px;
      padding-bottom: {{ block.settings.bottom_padding | times: 0.7 }}px;
    }

    .ai-blog-grid-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: {{ block.settings.header_spacing | times: 0.7 }}px;
    }

    .ai-blog-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-blog-grid-posts-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.6 }}px;
    }

    .ai-blog-grid-content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    .ai-blog-grid-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-blog-grid-excerpt-{{ ai_gen_id }} {
      font-size: {{ block.settings.excerpt_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<blog-posts-grid-{{ ai_gen_id }} class="ai-blog-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-grid-container-{{ ai_gen_id }}">
    {% if block.settings.show_heading or block.settings.show_view_all %}
      <div class="ai-blog-grid-header-{{ ai_gen_id }}">
        {% if block.settings.show_heading and block.settings.heading != blank %}
          <h2 class="ai-blog-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.show_view_all and blog %}
          {% if block.settings.button_style == 'primary' %}
            <a href="{{ pages.recipes.url }}" class="ai-blog-grid-view-all-{{ ai_gen_id }} ai-blog-grid-view-all-primary-{{ ai_gen_id }}">
              {{ block.settings.view_all_text }}
            </a>
          {% elsif block.settings.button_style == 'secondary' %}
            <a href="{{ pages.recipes.url }}" class="ai-blog-grid-view-all-{{ ai_gen_id }} ai-blog-grid-view-all-secondary-{{ ai_gen_id }}">
              {{ block.settings.view_all_text }}
            </a>
          {% else %}
            <a href="{{ pages.recipes.url }}" class="ai-blog-grid-view-all-{{ ai_gen_id }} ai-blog-grid-view-all-link-{{ ai_gen_id }}">
              {{ block.settings.view_all_text }}
            </a>
          {% endif %}
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-blog-grid-posts-{{ ai_gen_id }}">
      {% if blog %}
        {% for article in blog.articles limit: block.settings.posts_to_show %}
          <article class="ai-blog-grid-card-{{ ai_gen_id }}">
            <a href="{{ article.url }}" class="ai-blog-grid-image-wrapper-{{ ai_gen_id }}">
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt | escape }}"
                  class="ai-blog-grid-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                >
              {% else %}
                <div class="ai-blog-grid-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </a>

            <div class="ai-blog-grid-content-{{ ai_gen_id }}">
              <time class="ai-blog-grid-date-{{ ai_gen_id }}" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                {{ article.published_at | date: '%B %d, %Y' }}
              </time>

              <h3 class="ai-blog-grid-title-{{ ai_gen_id }}">
                <a href="{{ article.url }}" class="ai-blog-grid-title-link-{{ ai_gen_id }}">
                  {{ article.title }}
                </a>
              </h3>

              {% if article.excerpt != blank %}
                <div class="ai-blog-grid-excerpt-{{ ai_gen_id }}">
                  {{ article.excerpt | strip_html | truncate: 150 }}
                </div>
              {% endif %}

              <a href="{{ article.url }}" class="ai-blog-grid-read-more-{{ ai_gen_id }}">
                {{ block.settings.read_more_text }}
              </a>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..block.settings.posts_to_show) %}
          <article class="ai-blog-grid-card-{{ ai_gen_id }}">
            <div class="ai-blog-grid-image-wrapper-{{ ai_gen_id }}">
              <div class="ai-blog-grid-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>

            <div class="ai-blog-grid-content-{{ ai_gen_id }}">
              <time class="ai-blog-grid-date-{{ ai_gen_id }}">
                May 17, 2026
              </time>

              <h3 class="ai-blog-grid-title-{{ ai_gen_id }}">
                <span class="ai-blog-grid-title-link-{{ ai_gen_id }}">
                  Sample Recipe Title
                </span>
              </h3>

              <div class="ai-blog-grid-excerpt-{{ ai_gen_id }}">
                Discover the art of pairing premium honey with seasonal ingredients to create unforgettable culinary experiences.
              </div>

              <span class="ai-blog-grid-read-more-{{ ai_gen_id }}">
                {{ block.settings.read_more_text }}
              </span>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</blog-posts-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogPostsGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('blog-posts-grid-{{ ai_gen_id }}', BlogPostsGrid{{ ai_gen_id }});
  })();
</script>

