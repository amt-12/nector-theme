{% doc %}
  @prompt
    Create a popup that appears after a customer submits their email address on the email signup form. The popup should display a coupon code (customizable in theme settings) with a thank-you message, a close button, and an option to copy the code. Style it to match a premium honey brand with warm amber tones and clean typography.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-coupon-popup-{{ ai_gen_id }} {
    display: none;
    z-index: 9999 !important;
position: fixed !important;

    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 9999;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-coupon-popup-{{ ai_gen_id }}.active {
    display: flex;
    opacity: 1;
  }

  .ai-coupon-popup-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 40px;
    max-width: 500px;
    width: 90%;
    position: relative;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    transform: scale(0.9);
    transition: transform 0.3s ease;
  }

  .ai-coupon-popup-{{ ai_gen_id }}.active .ai-coupon-popup-content-{{ ai_gen_id }} {
    transform: scale(1);
  }

  .ai-coupon-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .ai-coupon-popup-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-coupon-popup-icon-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    margin: 0 auto 20px;
    background-color: {{ block.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-coupon-popup-icon-{{ ai_gen_id }} svg {
    width: 32px;
    height: 32px;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-coupon-popup-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ai-coupon-popup-message-{{ ai_gen_id }} {
    font-size: {{ block.settings.message_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .ai-coupon-popup-code-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.code_background }};
    border: 2px dashed {{ block.settings.code_border }};
    border-radius: {{ block.settings.code_border_radius }}px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .ai-coupon-popup-code-label-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-coupon-popup-code-{{ ai_gen_id }} {
    font-size: {{ block.settings.code_size }}px;
    color: {{ block.settings.code_color }};
    font-weight: 700;
    letter-spacing: 0.1em;
    margin: 0;
    font-family: monospace;
  }

  .ai-coupon-popup-copy-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: 14px 32px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    width: 100%;
  }

  .ai-coupon-popup-copy-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-coupon-popup-copy-btn-{{ ai_gen_id }}.copied {
    background-color: {{ block.settings.success_color }};
  }

  .ai-coupon-popup-footer-{{ ai_gen_id }} {
    margin-top: 20px;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  @media screen and (max-width: 749px) {
    .ai-coupon-popup-content-{{ ai_gen_id }} {
      padding: 32px 24px;
    }

    .ai-coupon-popup-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-coupon-popup-message-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.message_size }}px * 0.9);
    }

    .ai-coupon-popup-code-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.code_size }}px * 0.85);
    }
  }
{% endstyle %}

<coupon-popup-{{ ai_gen_id }}
  class="ai-coupon-popup-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-coupon-popup-content-{{ ai_gen_id }}">
    <button
      class="ai-coupon-popup-close-{{ ai_gen_id }}"
      aria-label="Close popup"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="ai-coupon-popup-icon-{{ ai_gen_id }}">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>

    <h2 class="ai-coupon-popup-heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>

    <p class="ai-coupon-popup-message-{{ ai_gen_id }}">
      {{ block.settings.message }}
    </p>

    <div class="ai-coupon-popup-code-wrapper-{{ ai_gen_id }}">
      <div class="ai-coupon-popup-code-label-{{ ai_gen_id }}">
        {{ block.settings.code_label }}
      </div>
      <p class="ai-coupon-popup-code-{{ ai_gen_id }}" id="coupon-code-{{ ai_gen_id }}">
        {{ block.settings.coupon_code }}
      </p>
    </div>

    <button
      class="ai-coupon-popup-copy-btn-{{ ai_gen_id }}"
      data-copy-text="{{ block.settings.coupon_code }}"
    >
      {{ block.settings.button_text }}
    </button>

    {% if block.settings.footer_text != blank %}
      <p class="ai-coupon-popup-footer-{{ ai_gen_id }}">
        {{ block.settings.footer_text }}
      </p>
    {% endif %}
  </div>
</coupon-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class SignupPopup{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        // Move to body to escape stacking context
        if (this.parentElement !== document.body) {
          document.body.appendChild(this);
          return; // connectedCallback will fire again after move
        }
        
        this.closeButton = this.querySelector('.ai-signup-popup-close-{{ ai_gen_id }}');
        this.copyButton = this.querySelector('.ai-signup-popup-copy-button-{{ ai_gen_id }}');
        this.overlay = this;
        this.setupEventListeners();
        this.checkForTrigger();
      }

      setupEventListeners() {
        this.closeButton.addEventListener('click', () => this.closePopup());
        
        this.overlay.addEventListener('click', (e) => {
          if (e.target === this.overlay) this.closePopup();
        });

        this.copyButton.addEventListener('click', () => this.copyCode());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.classList.contains('active')) this.closePopup();
        });
      }

      checkForTrigger() {
        const forms = document.querySelectorAll('form[action*="contact"]');
        forms.forEach(form => {
          form.addEventListener('submit', (e) => {
            const emailInput = form.querySelector('input[type="email"]');
            if (emailInput && emailInput.value) {
              setTimeout(() => this.openPopup(), 500);
            }
          });
        });

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('customer_posted') === 'true' || urlParams.get('contact_posted') === 'true') {
          setTimeout(() => this.openPopup(), 500);
        }
      }

      openPopup() {
        this.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closePopup() {
        this.classList.remove('active');
        document.body.style.overflow = '';
      }

      copyCode() {
        const code = this.copyButton.getAttribute('data-coupon-code');
        navigator.clipboard.writeText(code).then(() => {
          this.showCopiedState();
        }).catch(() => {
          this.fallbackCopy(code);
        });
      }

      fallbackCopy(text) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        document.body.appendChild(textArea);
        textArea.select();
        try { document.execCommand('copy'); this.showCopiedState(); } catch(err) {}
        document.body.removeChild(textArea);
      }

      showCopiedState() {
        const originalText = this.copyButton.textContent;
        this.copyButton.textContent = '{{ block.settings.copied_text }}';
        this.copyButton.classList.add('copied');
        setTimeout(() => {
          this.copyButton.textContent = originalText;
          this.copyButton.classList.remove('copied');
        }, 2000);
      }
    }

    customElements.define('signup-popup-{{ ai_gen_id }}', SignupPopup{{ ai_gen_id }});
  })();
</script>


{% schema %}
{
  "name": "Email signup coupon popup",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Thank you for subscribing!"
    },
    {
