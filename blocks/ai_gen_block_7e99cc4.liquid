{% doc %}
  @prompt
    Create a Liquid theme section called "Philosophy" for a premium honey brand. FULL PAGE WIDTH — 100vw, no max-width, no outer padding, edge to edge.
    
    LAYOUT: Two columns side by side, min-height 80vh.
    
    LEFT COLUMN (55%):
    - Black background (#0a0a0a)
    - A "media_type" select setting with options "image" and "video"
    - If media_type == "video": show a video (video picker setting) with autoplay, muted, loop, playsinline, object-fit: cover, full column height
    - If media_type == "image" (default): show image picker setting, object-fit: cover, full column height
    - Small uppercase label overlaid top-left in white (configurable text field)
    
    RIGHT COLUMN (45%):
    - Cream background (#F5F0E8)
    - Vertically centered, 60px padding
    - Large serif blockquote (~2.4rem, #1a1a1a): configurable text field, default: ‘We believe honey should be treated with the same reverence as wine.’
    - Thin divider line
    - Body text (~0.9rem, #444): configurable text field, default: "Single-origin. Cold-extracted. Fully traceable. From hive to jar without compromise."
    
    CRITICAL: Section outer wrapper: width:100%; max-width:100% !important; margin:0; padding:0; overflow:hidden;
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-philosophy-section-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100% !important;
    margin: 0;
    padding: 0;
    overflow: hidden;
    display: block;
  }

  .ai-philosophy-wrapper-{{ ai_gen_id }} {
    display: flex;
    min-height: 80vh;
    width: 100vw;
    margin: 0;
    padding: 0;
  }

  .ai-philosophy-left-{{ ai_gen_id }} {
    width: 55%;
    background-color: {{ block.settings.left_bg_color }};
    position: relative;
    overflow: hidden;
  }

  .ai-philosophy-media-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-philosophy-label-{{ ai_gen_id }} {
    position: absolute;
    top: 24px;
    left: 24px;
    color: {{ block.settings.label_color }};
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    z-index: 2;
  }

  .ai-philosophy-right-{{ ai_gen_id }} {
    width: 45%;
    background-color: {{ block.settings.right_bg_color }};
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px;
  }

  .ai-philosophy-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}rem;
    color: {{ block.settings.quote_color }};
    line-height: 1.3;
    margin: 0 0 32px 0;
    font-family: Georgia, serif;
    font-style: italic;
  }

  .ai-philosophy-divider-{{ ai_gen_id }} {
    width: 60px;
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 0 32px 0;
  }

  .ai-philosophy-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}rem;
    color: {{ block.settings.body_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-philosophy-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      min-height: auto;
    }

    .ai-philosophy-left-{{ ai_gen_id }},
    .ai-philosophy-right-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-philosophy-left-{{ ai_gen_id }} {
      min-height: 50vh;
    }

    .ai-philosophy-right-{{ ai_gen_id }} {
      padding: 40px 24px;
    }

    .ai-philosophy-quote-{{ ai_gen_id }} {
      font-size: 1.5rem;
    }

    .ai-philosophy-body-{{ ai_gen_id }} {
      font-size: 0.85rem;
    }
  }
{% endstyle %}

<div class="ai-philosophy-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-philosophy-wrapper-{{ ai_gen_id }}">
    <div class="ai-philosophy-left-{{ ai_gen_id }}">
      {% if block.settings.media_type == 'video' %}
        {% if block.settings.video != blank %}
          <video-background-component style="display: block; width: 100%; height: 100%;">
            <video
              class="ai-philosophy-media-{{ ai_gen_id }}"
              autoplay
              muted
              loop
              playsinline
              ref="videoElement"
            >
              <source data-video-source="{{ block.settings.video.sources[1].url }}" type="{{ block.settings.video.sources[1].mime_type }}" ref="videoSources[]">
            </video>
          </video-background-component>
        {% else %}
          <div class="ai-philosophy-media-{{ ai_gen_id }}" style="background-color: #1a1a1a; display: flex; align-items: center; justify-content: center; color: #666;">
            <p style="text-align: center; padding: 20px;">Next, add a video</p>
          </div>
        {% endif %}
      {% else %}
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-philosophy-media-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-philosophy-media-{{ ai_gen_id }}" style="background-color: #1a1a1a; display: flex; align-items: center; justify-content: center;">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      {% endif %}

      {% if block.settings.label != blank %}
        <div class="ai-philosophy-label-{{ ai_gen_id }}">
          {{ block.settings.label }}
        </div>
      {% endif %}
    </div>

    <div class="ai-philosophy-right-{{ ai_gen_id }}">
      {% if block.settings.quote != blank %}
        <blockquote class="ai-philosophy-quote-{{ ai_gen_id }}">
          {{ block.settings.quote }}
        </blockquote>
      {% endif %}

      <div class="ai-philosophy-divider-{{ ai_gen_id }}"></div>

      {% if block.settings.body_text != blank %}
        <p class="ai-philosophy-body-{{ ai_gen_id }}">
          {{ block.settings.body_text }}
        </p>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Philosophy",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Our Philosophy"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "left_bg_color",
      "label": "Left background color",
      "default": "#0a0a0a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Quote",
      "default": "We believe honey should be treated with the same reverence as wine."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Single-origin. Cold-extracted. Fully traceable. From hive to jar without compromise."
    },
    {
      "type": "header",
      "content": "Right column style"
    },
    {
      "type": "color",
      "id": "right_bg_color",
      "label": "Background color",
      "default": "#F5F0E8"
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Quote size",
      "min": 1,
      "max": 4,
      "step": 0.1,
      "unit": "rem",
      "default": 2.4
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Quote color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 0.5,
      "max": 2,
      "step": 0.1,
      "unit": "rem",
      "default": 0.9
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#1a1a1a"
    }
  ],
  "presets": [
    {
      "name": "Philosophy"
    }
  ]
}
{% endschema %}
