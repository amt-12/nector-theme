{% doc %}
  @prompt
    Create a "Shop This Recipe" section for Shopify blog article pages. It should display a row of product cards using the theme's default card styling. Each card shows the product image, product title, price, and a "Shop Now" button that links to the product page. The section should support 1–3 products, be configurable in the theme editor (merchant picks which products to feature), have a heading "Shop This Recipe" above the cards, and be designed to sit at the bottom of a recipe blog post. Use the theme's existing card and button styles — no custom colors or fonts.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-shop-recipe-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 0;
  }

  .ai-shop-recipe-heading-{{ ai_gen_id }} {
    margin: 0 0 24px;
    text-align: center;
  }

  .ai-shop-recipe-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .ai-shop-recipe-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products | size }}, 1fr);
    }
  }

  .ai-shop-recipe-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-shop-recipe-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-shop-recipe-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-shop-recipe-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-shop-recipe-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: 16px;
    line-height: 1.4;
  }

  .ai-shop-recipe-title-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
  }

  .ai-shop-recipe-title-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-shop-recipe-price-{{ ai_gen_id }} {
    font-size: 14px;
  }

  .ai-shop-recipe-button-{{ ai_gen_id }} {
    margin-top: 8px;
  }
{% endstyle %}

<div class="ai-shop-recipe-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-shop-recipe-heading-{{ ai_gen_id }} h3">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.products.size > 0 %}
    <div class="ai-shop-recipe-grid-{{ ai_gen_id }}">
      {% for product in block.settings.products %}
        <div class="ai-shop-recipe-card-{{ ai_gen_id }}">
          <div class="ai-shop-recipe-image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <a href="{{ product.url }}" class="ai-shop-recipe-image-link-{{ ai_gen_id }}">
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-shop-recipe-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              </a>
            {% else %}
              <div class="ai-shop-recipe-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-shop-recipe-info-{{ ai_gen_id }}">
            <h3 class="ai-shop-recipe-title-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-shop-recipe-title-link-{{ ai_gen_id }}">
                {{ product.title }}
              </a>
            </h3>

            <div class="ai-shop-recipe-price-{{ ai_gen_id }}">
              {% if product.compare_at_price > product.price %}
                <span class="price price--on-sale">
                  {{ product.price | money }}
                </span>
                <span class="price price--compare">
                  <s>{{ product.compare_at_price | money }}</s>
                </span>
              {% else %}
                <span class="price">
                  {{ product.price | money }}
                </span>
              {% endif %}
            </div>

            <div class="ai-shop-recipe-button-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="button button--primary">
                {{ block.settings.button_text }}
              </a>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Shop this recipe",
  "tag": null,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop This Recipe"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Products",
      "limit": 3
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Shop this recipe"
    }
  ]
}
{% endschema %}
