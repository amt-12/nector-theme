{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-faq-category-label-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ block.settings.category_label_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.category_label_spacing }};
    color: {{ block.settings.category_label_color }};
    margin-top: {{ block.settings.category_label_margin_top }}px;
    margin-bottom: {{ block.settings.category_label_margin_bottom }}px;
    font-weight: 400;
  }

  .ai-faq-category-label-{{ ai_gen_id }}:first-child {
    margin-top: 0;
  }

  .ai-faq-accordion-wrapper-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    margin-bottom: {{ block.settings.category_label_margin_top }}px;
  }

  .ai-faq-accordion-wrapper-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-faq-accordion-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-faq-accordion-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-faq-question-button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.question_padding_vertical }}px {{ block.settings.question_padding_horizontal }}px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.3s ease;
  }

  .ai-faq-question-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.question_hover_bg }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.question_font_size }}px;
    font-weight: {{ block.settings.question_font_weight }};
    color: {{ block.settings.question_color }};
    letter-spacing: {{ block.settings.question_letter_spacing }};
    line-height: 1.4;
    flex: 1;
    padding-right: 20px;
  }

  .ai-faq-caret-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .ai-faq-caret-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.caret_color }};
    stroke-width: 2;
    fill: none;
  }

  .ai-faq-accordion-item-{{ ai_gen_id }}.active .ai-faq-caret-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-answer-wrapper-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ block.settings.answer_font_size }}px;
    line-height: {{ block.settings.answer_line_height }};
    color: {{ block.settings.answer_color }};
    padding: {{ block.settings.answer_padding_vertical }}px {{ block.settings.answer_padding_horizontal }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-question-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_font_size | times: 0.9 }}px;
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-container-{{ ai_gen_id }}">
    {% if block.settings.category_1_label != blank %}
      <div class="ai-faq-category-label-{{ ai_gen_id }}">{{ block.settings.category_1_label }}</div>
      <div class="ai-faq-accordion-wrapper-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% assign q_key = 'q' | append: i %}
          {% assign a_key = 'a' | append: i %}
          {% if block.settings[q_key] != blank %}
            <div class="ai-faq-accordion-item-{{ ai_gen_id }}" data-faq-item>
              <button class="ai-faq-question-button-{{ ai_gen_id }}" aria-expanded="false">
                <span class="ai-faq-question-text-{{ ai_gen_id }}">{{ block.settings[q_key] }}</span>
                <span class="ai-faq-caret-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </span>
              </button>
              <div class="ai-faq-answer-wrapper-{{ ai_gen_id }}">
                <div class="ai-faq-answer-content-{{ ai_gen_id }}">{{ block.settings[a_key] }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

