{% doc %}
  @prompt
    Create a popup that appears after a customer submits their email on the signup form. Show a coupon code with a thank-you message and a copy button. Style it for a premium honey brand with warm amber tones. IMPORTANT: the popup overlay must use position: fixed, z-index: 99999, width: 100%, height: 100vh, top: 0, left: 0 so it fully covers the screen including the footer on mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-signup-popup-overlay-{{ ai_gen_id }} {
    position: fixed;
    z-index: 99999;
    width: 100%;
    height: 100vh;
    top: 0;
    left: 0;
    background-color: {{ block.settings.overlay_color }};
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-signup-popup-overlay-{{ ai_gen_id }}.active {
    display: flex;
    opacity: 1;
  }

  .ai-signup-popup-container-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.popup_background }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 40px;
    max-width: 500px;
    width: 90%;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    transform: scale(0.9);
    transition: transform 0.3s ease;
  }

  .ai-signup-popup-overlay-{{ ai_gen_id }}.active .ai-signup-popup-container-{{ ai_gen_id }} {
    transform: scale(1);
  }

  .ai-signup-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .ai-signup-popup-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-signup-popup-content-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-signup-popup-icon-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-signup-popup-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.accent_color }};
  }

  .ai-signup-popup-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
  }

  .ai-signup-popup-message-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    line-height: 1.6;
  }

  .ai-signup-popup-coupon-{{ ai_gen_id }} {
    background-color: {{ block.settings.coupon_background }};
    border: 2px dashed {{ block.settings.accent_color }};
    border-radius: {{ block.settings.coupon_border_radius }}px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .ai-signup-popup-coupon-label-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    opacity: 0.8;
  }

  .ai-signup-popup-coupon-code-{{ ai_gen_id }} {
    font-size: {{ block.settings.coupon_code_size }}px;
    color: {{ block.settings.accent_color }};
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 12px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
  }

  .ai-signup-popup-copy-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-signup-popup-copy-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-signup-popup-copy-button-{{ ai_gen_id }}:active {
    transform: translateY(0);
  }

  .ai-signup-popup-copy-button-{{ ai_gen_id }}.copied {
    background-color: {{ block.settings.success_color }};
  }

  .ai-signup-popup-footer-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin-top: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-signup-popup-container-{{ ai_gen_id }} {
      padding: 30px 20px;
    }

    .ai-signup-popup-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-signup-popup-message-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }
  }
{% endstyle %}

<signup-popup-{{ ai_gen_id }} class="ai-signup-popup-overlay-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-signup-popup-container-{{ ai_gen_id }}">
    <button
      class="ai-signup-popup-close-{{ ai_gen_id }}"
      aria-label="Close popup"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="ai-signup-popup-content-{{ ai_gen_id }}">
      {% if block.settings.show_icon %}
        <div class="ai-signup-popup-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
        </div>
      {% endif %}

      <h2 class="ai-signup-popup-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>

      <p class="ai-signup-popup-message-{{ ai_gen_id }}">
        {{ block.settings.message }}
      </p>

      <div class="ai-signup-popup-coupon-{{ ai_gen_id }}">
        <div class="ai-signup-popup-coupon-label-{{ ai_gen_id }}">
          {{ block.settings.coupon_label }}
        </div>
        <div class="ai-signup-popup-coupon-code-{{ ai_gen_id }}" id="ai-coupon-code-{{ ai_gen_id }}">
          {{ block.settings.coupon_code }}
        </div>
        <button
          class="ai-signup-popup-copy-button-{{ ai_gen_id }}"
          data-coupon-code="{{ block.settings.coupon_code }}"
        >
          {{ block.settings.copy_button_text }}
        </button>
      </div>

      {% if block.settings.footer_text != blank %}
        <p class="ai-signup-popup-footer-{{ ai_gen_id }}">
          {{ block.settings.footer_text }}
        </p>
      {% endif %}
    </div>
  </div>
</signup-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class SignupPopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.closeButton = this.querySelector('.ai-signup-popup-close-{{ ai_gen_id }}');
        this.copyButton = this.querySelector('.ai-signup-popup-copy-button-{{ ai_gen_id }}');
        this.overlay = this;
      }

      connectedCallback() {
        this.setupEventListeners();
        this.checkForTrigger();
      }

      setupEventListeners() {
        this.closeButton.addEventListener('click', () => this.closePopup());
        
        this.overlay.addEventListener('click', (e) => {
          if (e.target === this.overlay) {
            this.closePopup();
          }
        });

        this.copyButton.addEventListener('click', () => this.copyCode());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.classList.contains('active')) {
            this.closePopup();
          }
        });
      }

      checkForTrigger() {
        const forms = document.querySelectorAll('form[action*="contact"]');
        forms.forEach(form => {
          form.addEventListener('submit', (e) => {
            const emailInput = form.querySelector('input[type="email"]');
            if (emailInput && emailInput.value) {
              setTimeout(() => {
                const successMessage = document.querySelector('.ai-email-signup-form__success-{{ ai_gen_id }}');
                if (successMessage || form.classList.contains('submitted')) {
                  this.openPopup();
                }
              }, 500);
            }
          });
        });

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('customer_posted') === 'true' || urlParams.get('contact_posted') === 'true') {
          setTimeout(() => this.openPopup(), 500);
        }
      }

      openPopup() {
        this.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      closePopup() {
        this.classList.remove('active');
        document.body.style.overflow = '';
      }

      copyCode() {
        const code = this.copyButton.getAttribute('data-coupon-code');
        
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(code).then(() => {
            this.showCopiedState();
          }).catch(() => {
            this.fallbackCopy(code);
          });
        } else {
          this.fallbackCopy(code);
        }
      }

      fallbackCopy(text) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-999999px';
        document.body.appendChild(textArea);
        textArea.select();
        
        try {
          document.execCommand('copy');
          this.showCopiedState();
        } catch (err) {
          console.error('Failed to copy:', err);
        }
        
        document.body.removeChild(textArea);
      }

      showCopiedState() {
        const originalText = this.copyButton.textContent;
        this.copyButton.textContent = '{{ block.settings.copied_text }}';
        this.copyButton.classList.add('copied');
        
        setTimeout(() => {
          this.copyButton.textContent = originalText;
          this.copyButton.classList.remove('copied');
        }, 2000);
      }
    }

    customElements.define('signup-popup-{{ ai_gen_id }}', SignupPopup{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Email signup popup",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show success icon",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to the hive!"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "Thank you for joining our community. Here's a special gift to sweeten your first order."
    },
    {
      "type": "text",
      "id": "coupon_label",
      "label": "Coupon label",
      "default": "Your exclusive code"
    },
    {
      "type": "text",
      "id": "coupon_code",
      "label": "Coupon code",
      "default": "HONEY15"
    },
    {
      "type": "text",
      "id": "copy_button_text",
      "label": "Copy button text",
      "default": "Copy code"
    },
    {
      "type": "text",
      "id": "copied_text",
      "label": "Copied confirmation text",
      "default": "Copied!"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer text",
      "default": "Code valid for 30 days on orders over ₹500"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "rgba(59, 42, 26, 0.85)"
    },
    {
      "type": "color",
      "id": "popup_background",
      "label": "Popup background",
      "default": "#fafaf5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#3b2a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#6b5345"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#d4a574"
    },
    {
      "type": "color",
      "id": "coupon_background",
      "label": "Coupon background",
      "default": "#fff8e7"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#8b7355"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#6b5345"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success color",
      "default": "#5c8a5a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "cormorant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "coupon_code_size",
      "label": "Coupon code size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "Border radius"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Popup border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "coupon_border_radius",
      "label": "Coupon border radius",
      "min": 0,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "Email signup popup"
    }
  ]
}
{% endschema %}
