      "label": "Label",
      "default": "#8b7355"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "product_name_color",
      "label": "Product name",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Tagline",
      "default": "#6b5a48"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider",
      "default": "#e8dcc8"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
