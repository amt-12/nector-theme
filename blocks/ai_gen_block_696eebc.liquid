{% doc %}
  @prompt
    Create a full-width hero banner section that spans 100vw with no container max-width or side margins — bleeds edge to edge. The banner has a dark moody background image. Centered content stack in this exact order: 1) A large editorial headline (default: "10 grams of ritual."), 2) A subtext paragraph (default: "The Snap-Click Sachet. Precision-portioned. Entirely intentional."), 3) A price line (default: "From ₹299"), 4) A minimal outlined CTA button (default label: "Shop Snap-Click Sachets") linking to /collections/snap-click-sachets. All text white on the dark image. No heavy gradients. Premium, editorial aesthetic. All fields (headline, subtext, price, button label, button link, background image) must be customizable in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    min-height: {{ block.settings.min_height_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-hero-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-banner__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 60px 20px;
    max-width: 800px;
    width: 100%;
  }

  .ai-hero-banner__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.1;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_after_headline }}px;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .ai-hero-banner__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_after_subtext }}px;
    opacity: 0.9;
  }

  .ai-hero-banner__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_after_price }}px;
    font-weight: 500;
  }

  .ai-hero-banner__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_text_size }}px;
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_background_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    text-decoration: none;
    transition: all 0.3s ease;
    border-radius: {{ block.settings.button_border_radius }}px;
  }

  .ai-hero-banner__cta-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_hover_text_color }};
    background-color: {{ block.settings.button_hover_background_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-hero-banner__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-hero-banner__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-hero-banner__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.9 }}px;
    }

    .ai-hero-banner__content-{{ ai_gen_id }} {
      padding: 40px 20px;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-banner__empty-state-{{ ai_gen_id }}">
          Next, add a background image
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-banner__content-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-banner__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-hero-banner__subtext-{{ ai_gen_id }}">
        {{ block.settings.subtext }}
      </p>
    {% endif %}

    {% if block.settings.price_text != blank %}
      <p class="ai-hero-banner__price-{{ ai_gen_id }}">
        {{ block.settings.price_text }}
      </p>
    {% endif %}

    {% if block.settings.button_label != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-hero-banner__cta-{{ ai_gen_id }}"
      >
        {{ block.settings.button_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Hero banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Minimum height (desktop)",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Minimum height (mobile)",
      "min": 200,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "10 grams of ritual."
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Headline size",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "spacing_after_headline",
      "label": "Space after headline",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "The Snap-Click Sachet. Precision-portioned. Entirely intentional."
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Subtext size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "spacing_after_subtext",
      "label": "Space after subtext",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Price text",
      "default": "From ₹299"
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_after_price",
      "label": "Space after price",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Snap-Click Sachets"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Hover background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
