{% doc %}
  @prompt
    Create a premium collection filter navigation tab bar block with 4 tabs. Each tab must have its own schema settings for label (text) and URL (url input) so the merchant can edit them in the theme editor sidebar. Default values: Tab 1 label "All" url "/collections/all-products", Tab 2 label "Jars" url "/collections/jars", Tab 3 label "Snap-Click Sachets" url "/collections/snap-click-sachets", Tab 4 label "The Nectar Edit" url "/collections/the-nectar-edit". Highlight the active tab based on the current page URL using a thin underline. Style: minimal, elegant, luxury honey brand — clean horizontal tabs, generous spacing, no dropdowns, no buttons.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-nav-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-nav__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    gap: {{ block.settings.tab_spacing }}px;
    padding: {{ block.settings.vertical_padding }}px 0;
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-collection-nav__tab-{{ ai_gen_id }} {
    position: relative;
    display: inline-block;
    padding: {{ block.settings.tab_padding_vertical }}px {{ block.settings.tab_padding_horizontal }}px;
    font-family: {{ block.settings.tab_font.family }}, {{ block.settings.tab_font.fallback_families }};
    font-weight: {{ block.settings.tab_font.weight }};
    font-size: {{ block.settings.tab_font_size }}px;
    color: {{ block.settings.tab_text_color }};
    text-decoration: none;
    text-transform: {{ block.settings.tab_text_transform }};
    letter-spacing: {{ block.settings.tab_letter_spacing }}px;
    transition: color 0.3s ease;
  }

  .ai-collection-nav__tab-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_hover_color }};
  }

  .ai-collection-nav__tab-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * {{ block.settings.vertical_padding }}px - 1px);
    left: 0;
    width: 100%;
    height: {{ block.settings.underline_thickness }}px;
    background-color: {{ block.settings.active_underline_color }};
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-collection-nav__tab-{{ ai_gen_id }}.active::after {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-nav__container-{{ ai_gen_id }} {
      gap: {{ block.settings.tab_spacing | times: 0.7 }}px;
    }

    .ai-collection-nav__tab-{{ ai_gen_id }} {
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
      padding: {{ block.settings.tab_padding_vertical | times: 0.8 }}px {{ block.settings.tab_padding_horizontal | times: 0.7 }}px;
    }
  }
{% endstyle %}

<collection-nav-{{ ai_gen_id }}
  class="ai-collection-nav-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <nav class="ai-collection-nav__container-{{ ai_gen_id }}">
    {% if block.settings.tab_1_label != blank %}
      <a
        href="{{ block.settings.tab_1_url }}"
        class="ai-collection-nav__tab-{{ ai_gen_id }}"
        data-url="{{ block.settings.tab_1_url }}"
      >
        {{ block.settings.tab_1_label }}
      </a>
    {% endif %}

    {% if block.settings.tab_2_label != blank %}
      <a
        href="{{ block.settings.tab_2_url }}"
        class="ai-collection-nav__tab-{{ ai_gen_id }}"
        data-url="{{ block.settings.tab_2_url }}"
      >
        {{ block.settings.tab_2_label }}
      </a>
    {% endif %}

    {% if block.settings.tab_3_label != blank %}
      <a
        href="{{ block.settings.tab_3_url }}"
        class="ai-collection-nav__tab-{{ ai_gen_id }}"
        data-url="{{ block.settings.tab_3_url }}"
      >
        {{ block.settings.tab_3_label }}
      </a>
    {% endif %}

    {% if block.settings.tab_4_label != blank %}
      <a
        href="{{ block.settings.tab_4_url }}"
        class="ai-collection-nav__tab-{{ ai_gen_id }}"
        data-url="{{ block.settings.tab_4_url }}"
      >
        {{ block.settings.tab_4_label }}
      </a>
    {% endif %}
  </nav>
</collection-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-collection-nav__tab-{{ ai_gen_id }}');
        this.highlightActiveTab();
      }

      highlightActiveTab() {
        const currentPath = window.location.pathname;

        this.tabs.forEach((tab) => {
          const tabUrl = tab.getAttribute('data-url');
          
          if (tabUrl && currentPath.includes(tabUrl)) {
            tab.classList.add('active');
          } else {
            tab.classList.remove('active');
          }
        });
      }
    }

    customElements.define('collection-nav-{{ ai_gen_id }}', CollectionNav{{ ai_gen_id }});
  })();
</script>

