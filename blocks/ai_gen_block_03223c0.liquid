{% doc %}
  @prompt
    Email capture popup - no cookie suppression version. Shows on every page load.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-email-popup-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-email-popup-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-email-popup-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-email-popup-container-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    max-width: {{ block.settings.max_width }}px;
    width: 100%;
    padding: {{ block.settings.padding }}px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    text-align: center;
    z-index: 1;
  }

  .ai-email-popup-close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .ai-email-popup-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-email-popup-close-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-email-popup-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-email-popup-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-email-popup-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-email-popup-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-email-popup-input-{{ ai_gen_id }} {
    padding: 14px 16px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 16px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    transition: border-color 0.3s ease;
  }

  .ai-email-popup-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-email-popup-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
  }

  .ai-email-popup-button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-email-popup-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-email-popup-success-{{ ai_gen_id }} {
    display: none;
    flex-direction: column;
    gap: 16px;
  }

  .ai-email-popup-success-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-email-popup-success-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-email-popup-code-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-size: {{ block.settings.code_size }}px;
    font-weight: 700;
    color: {{ block.settings.code_color }};
    background-color: {{ block.settings.code_background }};
    padding: 16px 24px;
    border-radius: {{ block.settings.code_border_radius }}px;
    letter-spacing: 2px;
    margin: 0;
  }

  .ai-email-popup-success-message-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-email-popup-error-{{ ai_gen_id }} {
    display: none;
    color: {{ block.settings.error_color }};
    font-size: 14px;
    margin-top: -8px;
  }

  .ai-email-popup-error-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-email-popup-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-email-popup-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-email-popup-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-email-popup-code-{{ ai_gen_id }} {
      font-size: {{ block.settings.code_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<email-popup-{{ ai_gen_id }}
  class="ai-email-popup-{{ ai_gen_id }}"
  data-delay="{{ block.settings.delay }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-email-popup-overlay-{{ ai_gen_id }}"></div>
  <div class="ai-email-popup-container-{{ ai_gen_id }}">
    <button class="ai-email-popup-close-{{ ai_gen_id }}" aria-label="Close popup">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="ai-email-popup-content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-email-popup-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
      {% endif %}

      {% if block.settings.subtext != blank %}
        <div class="ai-email-popup-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
      {% endif %}

      {%- form 'contact', class: 'ai-email-popup-form-' | append: ai_gen_id -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          class="ai-email-popup-input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.email_placeholder }}"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          required
        >
        <div class="ai-email-popup-error-{{ ai_gen_id }}">
          Please enter a valid email address
        </div>
        <button type="submit" class="ai-email-popup-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>
      {%- endform -%}
    </div>

    <div class="ai-email-popup-success-{{ ai_gen_id }}">
      <h3 class="ai-email-popup-success-title-{{ ai_gen_id }}">{{ block.settings.success_title }}</h3>
      <div class="ai-email-popup-code-{{ ai_gen_id }}">{{ block.settings.discount_code }}</div>
      <p class="ai-email-popup-success-message-{{ ai_gen_id }}">{{ block.settings.success_message }}</p>
    </div>
  </div>
</email-popup-{{ ai_gen_id }}>

<script>
  (function() {
    class EmailPopup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.delay = parseInt(this.dataset.delay) * 1000;
      }

      connectedCallback() {
        this.popup = this;
        this.closeButton = this.querySelector('.ai-email-popup-close-{{ ai_gen_id }}');
        this.overlay = this.querySelector('.ai-email-popup-overlay-{{ ai_gen_id }}');
        this.form = this.querySelector('.ai-email-popup-form-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-email-popup-content-{{ ai_gen_id }}');
        this.successView = this.querySelector('.ai-email-popup-success-{{ ai_gen_id }}');
        this.errorMessage = this.querySelector('.ai-email-popup-error-{{ ai_gen_id }}');
        this.emailInput = this.querySelector('.ai-email-popup-input-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.showPopup();
      }

      showPopup() {
        setTimeout(() => {
          this.popup.classList.add('active');
          document.body.style.overflow = 'hidden';
        }, this.delay);
      }

      hidePopup() {
        this.popup.classList.remove('active');
        document.body.style.overflow = '';
      }

      setupEventListeners() {
        this.closeButton.addEventListener('click', () => {
          this.hidePopup();
        });

        this.overlay.addEventListener('click', () => {
          this.hidePopup();
        });

        this.form.addEventListener('submit', (e) => {
          e.preventDefault();

          const email = this.emailInput.value;
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

          if (!emailRegex.test(email)) {
            this.errorMessage.classList.add('active');
            return;
          }

          this.errorMessage.classList.remove('active');

          const formData = new FormData(this.form);

          fetch(this.form.action, {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/javascript' }
          }).then(() => {
            this.content.style.display = 'none';
            this.successView.classList.add('active');
          }).catch(() => {
            this.content.style.display = 'none';
            this.successView.classList.add('active');
          });
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.popup.classList.contains('active')) {
            this.hidePopup();
          }
        });
      }
    }

    customElements.define('email-popup-{{ ai_gen_id }}', EmailPopup{{ ai_gen_id }});
  })();
</script>

