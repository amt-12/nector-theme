      "default": "#e8dcc8"
    },
    {
      "type": "color",
      "id": "card_icon_color",
      "label": "Icon color",
      "default": "#8b7355"
    },
    {
      "type": "color",
      "id": "card_label_color",
      "label": "Label color",
      "default": "#8b7355"
    },
    {
      "type": "color",
      "id": "card_body_color",
      "label": "Body color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Card 1 - Email"
    },
    {
      "type": "text",
      "id": "card_1_label",
      "label": "Label",
      "default": "WRITE TO US"
    },
    {
      "type": "text",
      "id": "card_1_email",
      "label": "Email address",
      "default": "info@farmure.in"
