    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#c9bfb0"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "raleway_n4"
    },
    {
      "type": "header",
      "content": "Contact cards"
    },
    {
      "type": "color",
