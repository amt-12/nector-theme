{% doc %}
  @prompt
    Create a full-bleed cinematic contact page hero section for an ultra-luxury premium honey brand called NECTAR & COMB.
    
    Design requirements:
    - Full-width, full-bleed background image (using the existing shop image: shopify://shop_images/pure-and-natural.png)
    - Dark warm overlay on the image (gradient from bottom, color around #1a1612 at 70% opacity) so text is legible
    - Content is left-aligned, vertically centered, with generous left padding (matching a page-width container)
    - A small uppercase tracking label at the top: "CORRESPONDENCE" in gold (#c9a96e), 11px, letter-spacing 0.25em
    - A thin horizontal gold rule (1px, #c9a96e, ~40px wide) between the label and heading
    - Main heading: "We Welcome Your Enquiry" in serif font, ~52px, color #fafaf5, normal weight, line-height 1.15
    - Body copy below: "Our team is at your service. Whether you seek to learn more about our single-origin honeys, explore gifting, or simply wish to connect — we are here." in body font, 17px, color #c9bfb0, line-height 1.7
    - Minimum section height: 580px on desktop, 420px on mobile
    - Below the hero image, three contact info cards in a horizontal row on a cream (#fafaf5) background:
      - Card 1: "WRITE TO US" / "info@farmure.in" (clickable email link)
      - Card 2: "FOLLOW OUR JOURNEY" / "@nectarandcomb.in" (links to https://www.instagram.com/nectarandcomb)
      - Card 3: "OUR ATELIER" / "Plot No. 101, Sector-82, JLPL Industrial Area, SAS Nagar, Mohali, Punjab — 140308"
    - Cards: no heavy borders, just a subtle 1px #e8dcc8 border, 48px padding, card labels in #8b7355 at 11px uppercase tracked, card body in #1a1a1a at 16px
    - A small SVG icon per card (email, instagram, location pin) in #8b7355, stroke-width 1, 24px
    - No split layout. No side-by-side image/text panel. Pure editorial luxury feel.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 580px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .ai-contact-hero-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-contact-hero-bg-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-contact-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, {{ block.settings.overlay_color }} 0%, transparent 100%);
    z-index: 2;
  }

  .ai-contact-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: 1400px;
    margin: 0 auto;
    padding: 80px 60px;
    width: 100%;
  }

  .ai-contact-hero-label-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin-bottom: 16px;
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
  }

  .ai-contact-hero-rule-{{ ai_gen_id }} {
    width: 40px;
    height: 1px;
    background-color: {{ block.settings.label_color }};
    margin-bottom: 24px;
  }

  .ai-contact-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.15;
    margin: 0 0 24px 0;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    max-width: 600px;
  }

  .ai-contact-hero-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: 1.7;
    margin: 0;
    max-width: 540px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
  }

  .ai-contact-cards-{{ ai_gen_id }} {
    background-color: {{ block.settings.cards_bg_color }};
    padding: 60px 0;
  }

  .ai-contact-cards-wrapper-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 60px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .ai-contact-card-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.card_border_color }};
    padding: 48px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-card-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    color: {{ block.settings.card_icon_color }};
    margin-bottom: 8px;
  }

  .ai-contact-card-label-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ block.settings.card_label_color }};
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin: 0;
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
  }

  .ai-contact-card-body-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.card_body_color }};
    line-height: 1.6;
    margin: 0;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
  }

  .ai-contact-card-body-{{ ai_gen_id }} a {
    color: {{ block.settings.card_body_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-contact-card-body-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.card_icon_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-contact-hero-{{ ai_gen_id }} {
      min-height: 420px;
    }

    .ai-contact-hero-content-{{ ai_gen_id }} {
      padding: 60px 40px;
    }

    .ai-contact-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-contact-hero-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-contact-cards-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      padding: 0 40px;
      gap: 24px;
    }

    .ai-contact-card-{{ ai_gen_id }} {
      padding: 32px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-contact-hero-content-{{ ai_gen_id }} {
      padding: 40px 24px;
    }

    .ai-contact-cards-wrapper-{{ ai_gen_id }} {
      padding: 0 24px;
    }
  }
{% endstyle %}

<div class="ai-contact-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-hero-bg-{{ ai_gen_id }}">
    {% if block.settings.hero_image %}
      <img
        src="{{ block.settings.hero_image | image_url: width: 2400 }}"
        alt="{{ block.settings.hero_image.alt | escape }}"
        loading="eager"
        width="{{ block.settings.hero_image.width }}"
        height="{{ block.settings.hero_image.height }}"
      >
    {% else %}
      <div style="width: 100%; height: 100%; background-color: #1a1612;">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>
  <div class="ai-contact-hero-overlay-{{ ai_gen_id }}"></div>
  <div class="ai-contact-hero-content-{{ ai_gen_id }}">
    {% if block.settings.label != blank %}
      <div class="ai-contact-hero-label-{{ ai_gen_id }}">{{ block.settings.label }}</div>
    {% endif %}
    <div class="ai-contact-hero-rule-{{ ai_gen_id }}"></div>
    {% if block.settings.heading != blank %}
      <h1 class="ai-contact-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
    {% endif %}
    {% if block.settings.body != blank %}
      <p class="ai-contact-hero-body-{{ ai_gen_id }}">{{ block.settings.body }}</p>
    {% endif %}
  </div>
</div>

<div class="ai-contact-cards-{{ ai_gen_id }}">
  <div class="ai-contact-cards-wrapper-{{ ai_gen_id }}">
    <div class="ai-contact-card-{{ ai_gen_id }}">
      <svg class="ai-contact-card-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      <p class="ai-contact-card-label-{{ ai_gen_id }}">{{ block.settings.card_1_label }}</p>
      <div class="ai-contact-card-body-{{ ai_gen_id }}">
        <a href="mailto:{{ block.settings.card_1_email }}">{{ block.settings.card_1_email }}</a>
      </div>
    </div>

    <div class="ai-contact-card-{{ ai_gen_id }}">
      <svg class="ai-contact-card-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
      </svg>
      <p class="ai-contact-card-label-{{ ai_gen_id }}">{{ block.settings.card_2_label }}</p>
      <div class="ai-contact-card-body-{{ ai_gen_id }}">
        <a href="{{ block.settings.card_2_link }}" target="_blank" rel="noopener">{{ block.settings.card_2_handle }}</a>
      </div>
    </div>

    <div class="ai-contact-card-{{ ai_gen_id }}">
      <svg class="ai-contact-card-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <p class="ai-contact-card-label-{{ ai_gen_id }}">{{ block.settings.card_3_label }}</p>
      <div class="ai-contact-card-body-{{ ai_gen_id }}">{{ block.settings.card_3_address }}</div>
    </div>
  </div>
</div>

