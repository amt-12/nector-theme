{% doc %}
  @prompt
    Create a custom navigation tab bar with four tabs linking to specific collections: "All" linking to /collections/all-products, "Jars" linking to /collections/jars, "Snap-Click Sachets" linking to /collections/snap-click-sachets, and "The Nectar Edit" linking to /collections/the-nectar-edit. The active tab based on current URL should be highlighted. Style should be minimal, premium, and elegant — thin underline or subtle pill style tabs, matching a luxury honey brand aesthetic. Clean horizontal tabs, no dropdowns.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-nav-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collection-nav__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    gap: {{ block.settings.tab_spacing }}px;
    padding: {{ block.settings.vertical_padding }}px 0;
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-collection-nav__tab-{{ ai_gen_id }} {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: {{ block.settings.tab_padding_vertical }}px {{ block.settings.tab_padding_horizontal }}px;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {% if block.settings.text_uppercase %}uppercase{% else %}none{% endif %};
    transition: color 0.2s ease, background-color 0.2s ease;
    border-radius: {{ block.settings.tab_border_radius }}px;
    background-color: transparent;
  }

  .ai-collection-nav__tab-{{ ai_gen_id }}:hover {
    color: {{ block.settings.hover_color }};
    background-color: {{ block.settings.hover_background }};
  }

  .ai-collection-nav__tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.active_color }};
    background-color: {{ block.settings.active_background }};
  }

  {% if block.settings.underline_style == 'underline' %}
    .ai-collection-nav__tab-{{ ai_gen_id }}::after {
      content: '';
      position: absolute;
      bottom: calc(-1 * {{ block.settings.vertical_padding }}px - {{ block.settings.border_width }}px);
      left: 0;
      right: 0;
      height: {{ block.settings.underline_height }}px;
      background-color: transparent;
      transition: background-color 0.2s ease;
    }

    .ai-collection-nav__tab-{{ ai_gen_id }}.active::after {
      background-color: {{ block.settings.active_underline_color }};
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-collection-nav__container-{{ ai_gen_id }} {
      gap: {{ block.settings.tab_spacing_mobile }}px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-collection-nav__container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-collection-nav__tab-{{ ai_gen_id }} {
      white-space: nowrap;
      font-size: {{ block.settings.font_size_mobile }}px;
      padding: {{ block.settings.tab_padding_vertical_mobile }}px {{ block.settings.tab_padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<collection-nav-{{ ai_gen_id }} class="ai-collection-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <nav class="ai-collection-nav__container-{{ ai_gen_id }}" role="navigation" aria-label="Collection navigation">
    <a
      href="/collections/all-products"
      class="ai-collection-nav__tab-{{ ai_gen_id }}"
      data-collection-path="/collections/all-products"
    >
      {{ block.settings.tab_1_label }}
    </a>
    <a
      href="/collections/jars"
      class="ai-collection-nav__tab-{{ ai_gen_id }}"
      data-collection-path="/collections/jars"
    >
      {{ block.settings.tab_2_label }}
    </a>
    <a
      href="/collections/snap-click-sachets"
      class="ai-collection-nav__tab-{{ ai_gen_id }}"
      data-collection-path="/collections/snap-click-sachets"
    >
      {{ block.settings.tab_3_label }}
    </a>
    <a
      href="/collections/the-nectar-edit"
      class="ai-collection-nav__tab-{{ ai_gen_id }}"
      data-collection-path="/collections/the-nectar-edit"
    >
      {{ block.settings.tab_4_label }}
    </a>
  </nav>
</collection-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-collection-nav__tab-{{ ai_gen_id }}');
        this.setActiveTab();
      }

      setActiveTab() {
        const currentPath = window.location.pathname;
        
        this.tabs.forEach((tab) => {
          const tabPath = tab.getAttribute('data-collection-path');
          
          if (currentPath === tabPath || currentPath.startsWith(tabPath + '/')) {
            tab.classList.add('active');
          } else {
            tab.classList.remove('active');
          }
        });
      }
    }

    customElements.define('collection-nav-{{ ai_gen_id }}', CollectionNav{{ ai_gen_id }});
  })();
</script>

