{% doc %}
  @prompt
    Create a full-width two-column editorial split section for an About Us page. No container constraints — 100vw full bleed. Left column (cream/off-white background): small all-caps label "CHAPTER 2" at top, large serif headline "Single-origin. Cold-extracted. Fully traceable." (each phrase on its own line), followed by two body text paragraphs. A "Shop Now" button below the text that links to /products/9309163815163. Right column: full-height product image of a Eucalyptus honey jar on a dark moody background. Overlaid on the image in large italic serif gold/cream text: 'We treat honey like wine. Origin is everything.' Both columns equal height, image fills the right column completely. Premium, editorial, minimalist aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-split-{{ ai_gen_id }} {
    display: block;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  .ai-editorial-split__container-{{ ai_gen_id }} {
    display: flex;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-editorial-split__column-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-split__text-column-{{ ai_gen_id }} {
    background-color: {{ block.settings.text_bg_color }};
    padding: {{ block.settings.text_padding }}px;
  }

  .ai-editorial-split__text-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.text_max_width }}px;
  }

  .ai-editorial-split__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    letter-spacing: {{ block.settings.label_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.label_color }};
    margin-bottom: {{ block.settings.label_margin }}px;
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
  }

  .ai-editorial-split__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    line-height: {{ block.settings.headline_line_height }};
    color: {{ block.settings.headline_color }};
    margin-bottom: {{ block.settings.headline_margin }}px;
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-style: {{ block.settings.headline_font.style }};
  }

  .ai-editorial-split__body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    color: {{ block.settings.body_color }};
    margin-bottom: {{ block.settings.body_margin }}px;
  }

  .ai-editorial-split__body-{{ ai_gen_id }} p {
    margin-bottom: 1em;
  }

  .ai-editorial-split__body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-editorial-split__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    text-transform: {{ block.settings.button_text_transform }};
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
  }

  .ai-editorial-split__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-editorial-split__image-column-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-editorial-split__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-split__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1c1812;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-split__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-editorial-split__overlay-text-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: {{ block.settings.overlay_size }}px;
    line-height: {{ block.settings.overlay_line_height }};
    color: {{ block.settings.overlay_color }};
    font-family: {{ block.settings.overlay_font.family }}, {{ block.settings.overlay_font.fallback_families }};
    font-weight: {{ block.settings.overlay_font.weight }};
    font-style: {{ block.settings.overlay_font.style }};
    text-align: center;
    max-width: 80%;
    z-index: 2;
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-split__container-{{ ai_gen_id }} {
      flex-direction: column;
      min-height: auto;
    }

    .ai-editorial-split__text-column-{{ ai_gen_id }} {
      padding: {{ block.settings.text_padding | times: 0.6 }}px;
    }

    .ai-editorial-split__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.8 }}px;
    }

    .ai-editorial-split__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-editorial-split__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-editorial-split__overlay-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.overlay_size | times: 0.5 }}px;
    }

    .ai-editorial-split__image-column-{{ ai_gen_id }} {
      min-height: 400px;
    }
  }
{% endstyle %}

<editorial-split-{{ ai_gen_id }} class="ai-editorial-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-split__container-{{ ai_gen_id }}">
    <div class="ai-editorial-split__column-{{ ai_gen_id }} ai-editorial-split__text-column-{{ ai_gen_id }}">
      <div class="ai-editorial-split__text-content-{{ ai_gen_id }}">
        {% if block.settings.label != blank %}
          <div class="ai-editorial-split__label-{{ ai_gen_id }}">{{ block.settings.label }}</div>
        {% endif %}

        {% if block.settings.headline != blank %}
          <h2 class="ai-editorial-split__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
        {% endif %}

        {% if block.settings.body_text != blank %}
          <div class="ai-editorial-split__body-{{ ai_gen_id }}">{{ block.settings.body_text }}</div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-editorial-split__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-editorial-split__column-{{ ai_gen_id }} ai-editorial-split__image-column-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-editorial-split__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-split__image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.overlay_text != blank %}
        <div class="ai-editorial-split__overlay-text-{{ ai_gen_id }}">{{ block.settings.overlay_text }}</div>
      {% endif %}
    </div>
  </div>
</editorial-split-{{ ai_gen_id }}>

<script>
  (function() {
    class EditorialSplit{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('editorial-split-{{ ai_gen_id }}', EditorialSplit{{ ai_gen_id }});
  })();
</script>

