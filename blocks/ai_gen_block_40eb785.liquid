{% doc %}
  @prompt
    Create a "Blog Posts Grid" section that displays a grid of blog post cards from a selected blog. The section should include: a section heading, a grid of blog post cards (with featured image, title, excerpt, date, and read more link), configurable number of posts to show, and a "View All" button with a fully customizable URL field (so merchants can link it to any page, not just the blog). Style it to match a premium, editorial aesthetic with clean typography and earthy tones., give 3 coloumn option , view all recipes button should have option of its type like link secondary and an option to place it at top right aligned with heading , button should be underlined and no arrow. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-blog-grid-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-blog-grid-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 48px;
    {% if block.settings.heading_alignment == 'center' and block.settings.button_position == 'bottom' %}
      justify-content: center;
    {% elsif block.settings.heading_alignment == 'left' and block.settings.button_position == 'bottom' %}
      justify-content: flex-start;
    {% elsif block.settings.heading_alignment == 'right' and block.settings.button_position == 'bottom' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-blog-grid-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-blog-grid-posts-{{ ai_gen_id }} {
    display: grid;
    {% if block.settings.columns_desktop == 2 %}
      grid-template-columns: repeat(2, 1fr);
    {% elsif block.settings.columns_desktop == 3 %}
      grid-template-columns: repeat(3, 1fr);
    {% elsif block.settings.columns_desktop == 4 %}
      grid-template-columns: repeat(4, 1fr);
    {% else %}
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    {% endif %}
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 48px;
  }

  .ai-blog-grid-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .ai-blog-grid-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-blog-grid-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-blog-grid-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-blog-grid-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-blog-grid-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-blog-grid-card-content-{{ ai_gen_id }} {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-blog-grid-date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.date_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .ai-blog-grid-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    line-height: 1.3;
  }

  .ai-blog-grid-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.excerpt_color }};
    line-height: 1.6;
    margin-bottom: 16px;
    flex-grow: 1;
  }

  .ai-blog-grid-read-more-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.3s ease;
  }

  .ai-blog-grid-read-more-{{ ai_gen_id }}:hover {
    gap: 12px;
  }

  .ai-blog-grid-read-more-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
  }

  .ai-blog-grid-view-all-wrapper-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-blog-grid-view-all-{{ ai_gen_id }} {
    display: inline-block;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }

  .ai-blog-grid-view-all-{{ ai_gen_id }}.ai-blog-grid-button-primary-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
  }

  .ai-blog-grid-view-all-{{ ai_gen_id }}.ai-blog-grid-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-blog-grid-view-all-{{ ai_gen_id }}.ai-blog-grid-button-secondary-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: transparent;
    color: {{ block.settings.button_background }};
    border: 1px solid {{ block.settings.button_background }};
    border-radius: {{ block.settings.button_border_radius }}px;
  }

  .ai-blog-grid-view-all-{{ ai_gen_id }}.ai-blog-grid-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-blog-grid-view-all-{{ ai_gen_id }}.ai-blog-grid-button-link-{{ ai_gen_id }} {
    color: {{ block.settings.button_background }};
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .ai-blog-grid-view-all-{{ ai_gen_id }}.ai-blog-grid-button-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-blog-grid-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.excerpt_color }};
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-blog-grid-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-blog-grid-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .ai-blog-grid-posts-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-blog-grid-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-blog-grid-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }
  }
{% endstyle %}

<blog-posts-grid-{{ ai_gen_id }} class="ai-blog-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.show_view_all %}
      <div class="ai-blog-grid-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-blog-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.show_view_all and block.settings.view_all_url != blank and block.settings.button_position == 'top' %}
          <a 
            href="{{ block.settings.view_all_url }}" 
            class="ai-blog-grid-view-all-{{ ai_gen_id }} ai-blog-grid-button-{{ block.settings.button_style }}-{{ ai_gen_id }}"
          >
            {{ block.settings.view_all_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.blog != blank %}
      {% assign blog = block.settings.blog %}
      {% assign posts_to_show = block.settings.posts_count %}
      
      {% if blog.articles_count > 0 %}
        <div class="ai-blog-grid-posts-{{ ai_gen_id }}">
          {% for article in blog.articles limit: posts_to_show %}
            <a href="{{ article.url }}" class="ai-blog-grid-card-{{ ai_gen_id }}">
              <div class="ai-blog-grid-image-wrapper-{{ ai_gen_id }}">
                {% if article.image %}
                  <img
                    src="{{ article.image | image_url: width: 600 }}"
                    alt="{{ article.image.alt | escape }}"
                    class="ai-blog-grid-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="400"
                  >
                {% else %}
                  <div class="ai-blog-grid-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              
              <div class="ai-blog-grid-card-content-{{ ai_gen_id }}">
                {% if block.settings.show_date %}
                  <div class="ai-blog-grid-date-{{ ai_gen_id }}">
                    {{ article.published_at | date: '%B %d, %Y' }}
                  </div>
                {% endif %}
                
                <h3 class="ai-blog-grid-title-{{ ai_gen_id }}">{{ article.title }}</h3>
                
                {% if block.settings.show_excerpt and article.excerpt != blank %}
                  <div class="ai-blog-grid-excerpt-{{ ai_gen_id }}">
                    {{ article.excerpt | strip_html | truncate: block.settings.excerpt_length }}
                  </div>
                {% endif %}
                
                <div class="ai-blog-grid-read-more-{{ ai_gen_id }}">
                  {{ block.settings.read_more_text }}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>

        {% if block.settings.show_view_all and block.settings.view_all_url != blank and block.settings.button_position == 'bottom' %}
          <div class="ai-blog-grid-view-all-wrapper-{{ ai_gen_id }}">
            <a 
              href="{{ block.settings.view_all_url }}" 
              class="ai-blog-grid-view-all-{{ ai_gen_id }} ai-blog-grid-button-{{ block.settings.button_style }}-{{ ai_gen_id }}"
            >
              {{ block.settings.view_all_text }}
            </a>
          </div>
        {% endif %}
      {% else %}
        <div class="ai-blog-grid-empty-{{ ai_gen_id }}">
          No articles found in this blog.
        </div>
      {% endif %}
    {% else %}
      <div class="ai-blog-grid-empty-{{ ai_gen_id }}">
        Select a blog to display posts.
      </div>
    {% endif %}
  </div>
</blog-posts-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogPostsGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-blog-grid-card-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          card.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('blog-posts-grid-{{ ai_gen_id }}', BlogPostsGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Blog posts grid",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Journal"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "posts_count",
      "label": "Number of posts",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Post display"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "range",
      "id": "excerpt_length",
      "label": "Excerpt length",
      "min": 50,
      "max": 200,
      "step": 10,
      "default": 120
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read more text",
      "default": "Read More"
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "checkbox",
