{% doc %}
  @prompt
    Regenerate the Product Showcase block for a luxury honey brand homepage. The block has two parts: left side shows a featured product with a large image, right side shows a vertical list of 3 products each with a small thumbnail image. Include these specific settings: (1) a range slider to control the featured product image width as a percentage (30% to 100%), (2) a range slider to control the featured product image height/aspect ratio — options from very short (0.5) to very tall (1.5) so the merchant can control exactly how tall the image appears, (3) a range slider to control the list product thumbnail image size in pixels (60px to 200px), (4) section label text, heading text, subheading text, (5) featured product picker with tagline field, (6) three product pickers each with a tagline field, (7) grid gap slider, max width slider, top/bottom padding sliders, horizontal padding slider, (8) color pickers for background, heading, subheading, product name, price, tagline, divider, (9) font size controls for heading, subheading, featured product name, list product name, (10) a "View All" button at the bottom center — with text field (default: "View All"), URL/link field, button style selector (solid or outline), and show/hide toggle. Design must be clean, editorial, ultra-luxury — Cormorant serif for all headings and product names, subtle horizontal dividers between list items, prices displayed inline next to product names, generous whitespace throughout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-product-showcase-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-product-showcase-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-product-showcase-label-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 14px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.subheading_color }};
    margin-bottom: 12px;
  }

  .ai-product-showcase-heading-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-product-showcase-subheading-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.subheading_font_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-product-showcase-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 48px;
  }

  .ai-product-showcase-featured-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-product-showcase-featured-image-{{ ai_gen_id }} {
    width: {{ block.settings.featured_image_width }}%;
    aspect-ratio: {{ block.settings.featured_image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-product-showcase-featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-product-showcase-featured-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-showcase-featured-name-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.featured_product_name_font_size }}px;
    color: {{ block.settings.product_name_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-product-showcase-featured-price-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.featured_product_name_font_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-showcase-featured-tagline-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 16px;
    color: {{ block.settings.tagline_color }};
    font-style: italic;
    margin: 0;
    line-height: 1.5;
  }

  .ai-product-showcase-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }}:first-child {
    padding-top: 0;
  }

  .ai-product-showcase-list-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-product-showcase-list-image-{{ ai_gen_id }} {
    width: {{ block.settings.list_thumbnail_size }}px;
    height: {{ block.settings.list_thumbnail_size }}px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .ai-product-showcase-list-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-showcase-list-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-showcase-list-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-showcase-list-info-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-product-showcase-list-name-price-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .ai-product-showcase-list-name-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.list_product_name_font_size }}px;
    color: {{ block.settings.product_name_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-product-showcase-list-price-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: {{ block.settings.list_product_name_font_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-showcase-list-tagline-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 14px;
    color: {{ block.settings.tagline_color }};
    font-style: italic;
    margin: 0;
    line-height: 1.5;
  }

  .ai-product-showcase-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .ai-product-showcase-button-{{ ai_gen_id }} {
    font-family: 'Cormorant', serif;
    font-size: 18px;
    padding: 14px 40px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 1px solid {{ block.settings.heading_color }};
  }

  .ai-product-showcase-button-solid-{{ ai_gen_id }} {
    background-color: {{ block.settings.heading_color }};
    color: {{ block.settings.background_color }};
  }

  .ai-product-showcase-button-solid-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.heading_color }};
  }

  .ai-product-showcase-button-outline-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.heading_color }};
  }

  .ai-product-showcase-button-outline-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.heading_color }};
    color: {{ block.settings.background_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-showcase-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-product-showcase-featured-image-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-product-showcase-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_font_size }}px * 0.7);
    }

    .ai-product-showcase-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_font_size }}px * 0.9);
    }

    .ai-product-showcase-featured-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.featured_product_name_font_size }}px * 0.85);
    }

    .ai-product-showcase-list-name-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.list_product_name_font_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-product-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-showcase-container-{{ ai_gen_id }}">
    {% if block.settings.section_label != blank or block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-product-showcase-header-{{ ai_gen_id }}">
        {% if block.settings.section_label != blank %}
          <div class="ai-product-showcase-label-{{ ai_gen_id }}">{{ block.settings.section_label }}</div>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h2 class="ai-product-showcase-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-product-showcase-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-product-showcase-grid-{{ ai_gen_id }}">
      <div class="ai-product-showcase-featured-{{ ai_gen_id }}">
        {% if block.settings.featured_product != blank %}
          <div class="ai-product-showcase-featured-image-{{ ai_gen_id }}">
            {% if block.settings.featured_product.featured_image %}
              <img
                src="{{ block.settings.featured_product.featured_image | image_url: width: 1200 }}"
                alt="{{ block.settings.featured_product.featured_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.featured_product.featured_image.width }}"
                height="{{ block.settings.featured_product.featured_image.height }}"
              >
            {% else %}
              <div class="ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-product-showcase-featured-info-{{ ai_gen_id }}">
            <h3 class="ai-product-showcase-featured-name-{{ ai_gen_id }}">{{ block.settings.featured_product.title }}</h3>
            <p class="ai-product-showcase-featured-price-{{ ai_gen_id }}">{{ block.settings.featured_product.price | money }}</p>
            {% if block.settings.featured_tagline != blank %}
              <p class="ai-product-showcase-featured-tagline-{{ ai_gen_id }}">{{ block.settings.featured_tagline }}</p>
            {% endif %}
          </div>
        {% else %}
          <div class="ai-product-showcase-featured-image-{{ ai_gen_id }}">
            <div class="ai-product-showcase-featured-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          </div>
          <div class="ai-product-showcase-featured-info-{{ ai_gen_id }}">
            <h3 class="ai-product-showcase-featured-name-{{ ai_gen_id }}">Featured Product</h3>
            <p class="ai-product-showcase-featured-price-{{ ai_gen_id }}">₹0.00</p>
          </div>
        {% endif %}
      </div>

      <div class="ai-product-showcase-list-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign product_key = 'list_product_' | append: i
            assign tagline_key = 'list_tagline_' | append: i
            assign product = block.settings[product_key]
            assign tagline = block.settings[tagline_key]
          %}
          <div class="ai-product-showcase-list-item-{{ ai_gen_id }}">
            <div class="ai-product-showcase-list-image-{{ ai_gen_id }}">
              {% if product != blank and product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {% else %}
                <div class="ai-product-showcase-list-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-product-showcase-list-info-{{ ai_gen_id }}">
              <div class="ai-product-showcase-list-name-price-{{ ai_gen_id }}">
                {% if product != blank %}
                  <h4 class="ai-product-showcase-list-name-{{ ai_gen_id }}">{{ product.title }}</h4>
                  <span class="ai-product-showcase-list-price-{{ ai_gen_id }}">{{ product.price | money }}</span>
                {% else %}
                  <h4 class="ai-product-showcase-list-name-{{ ai_gen_id }}">Product {{ i }}</h4>
                  <span class="ai-product-showcase-list-price-{{ ai_gen_id }}">₹0.00</span>
                {% endif %}
              </div>
              {% if tagline != blank %}
                <p class="ai-product-showcase-list-tagline-{{ ai_gen_id }}">{{ tagline }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {% if block.settings.show_view_all_button %}
      <div class="ai-product-showcase-button-wrapper-{{ ai_gen_id }}">
        <a
          href="{{ block.settings.view_all_link }}"
          class="ai-product-showcase-button-{{ ai_gen_id }} {% if block.settings.button_style == 'solid' %}ai-product-showcase-button-solid-{{ ai_gen_id }}{% else %}ai-product-showcase-button-outline-{{ ai_gen_id }}{% endif %}"
        >
          {{ block.settings.view_all_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Product showcase",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "section_label",
      "label": "Label",
      "default": "Our Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Pure Honey"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Handcrafted from the finest sources"
    },
    {
      "type": "header",
      "content": "Featured product"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "featured_tagline",
      "label": "Tagline"
    },
    {
      "type": "range",
      "id": "featured_image_width",
      "label": "Image width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "range",
      "id": "featured_image_aspect_ratio",
      "label": "Image aspect ratio",
      "min": 0.5,
      "max": 1.5,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "header",
      "content": "List product 1"
    },
    {
      "type": "product",
      "id": "list_product_1",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "list_tagline_1",
      "label": "Tagline"
    },
    {
      "type": "header",
      "content": "List product 2"
    },
    {
      "type": "product",
      "id": "list_product_2",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "list_tagline_2",
      "label": "Tagline"
    },
    {
      "type": "header",
      "content": "List product 3"
    },
    {
      "type": "product",
      "id": "list_product_3",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "list_tagline_3",
      "label": "Tagline"
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "outline",
          "label": "Outline"
        }
      ],
      "default": "outline"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 80,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "list_thumbnail_size",
      "label": "List thumbnail size",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fafaf5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "product_name_color",
      "label": "Product name",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Tagline",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider",
      "default": "#e8dcc8"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Subheading size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "featured_product_name_font_size",
      "label": "Featured product name size",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "list_product_name_font_size",
      "label": "List product name size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Product showcase"
    }
  ]
}
{% endschema %}