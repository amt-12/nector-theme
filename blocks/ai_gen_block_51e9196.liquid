{% doc %}
  @prompt
    Create a full-width hero section for an About Us page. Full-bleed background image spanning the entire viewport width with no margins or padding. Overlaid text in the bottom-left corner: small all-caps label "CHAPTER 1" in muted light color, large serif headline "The world is full of honey that isn’t really honey." in white, smaller subheadline "We started Nectar & Comb because we tasted the difference." in white. Min-height 70-80vh. Subtle dark gradient overlay at bottom-left for legibility. Premium, editorial, minimalist aesthetic. Section must be 100vw full bleed with no container constraints.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-fullbleed-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    min-height: {{ block.settings.min_height }}vh;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .ai-hero-fullbleed__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .ai-hero-fullbleed__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    z-index: 1;
  }

  .ai-hero-fullbleed__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-fullbleed__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to top right,
      {{ block.settings.overlay_color }} 0%,
      rgba(0, 0, 0, 0) {{ block.settings.overlay_spread }}%
    );
    z-index: 2;
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-hero-fullbleed__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding: {{ block.settings.content_padding_vertical }}px {{ block.settings.content_padding_horizontal }}px;
    max-width: {{ block.settings.content_max_width }}px;
  }

  .ai-hero-fullbleed__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.label_letter_spacing }}px;
    margin-bottom: {{ block.settings.label_spacing }}px;
    font-family: {{ block.settings.label_font.family }}, {{ block.settings.label_font.fallback_families }};
    font-weight: {{ block.settings.label_font.weight }};
    font-style: {{ block.settings.label_font.style }};
  }

  .ai-hero-fullbleed__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin-bottom: {{ block.settings.headline_spacing }}px;
    line-height: {{ block.settings.headline_line_height }};
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-style: {{ block.settings.headline_font.style }};
  }

  .ai-hero-fullbleed__subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.subheadline_color }};
    line-height: {{ block.settings.subheadline_line_height }};
    font-family: {{ block.settings.subheadline_font.family }}, {{ block.settings.subheadline_font.fallback_families }};
    font-weight: {{ block.settings.subheadline_font.weight }};
    font-style: {{ block.settings.subheadline_font.style }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-fullbleed-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}vh;
    }

    .ai-hero-fullbleed__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_vertical_mobile }}px {{ block.settings.content_padding_horizontal_mobile }}px;
    }

    .ai-hero-fullbleed__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size_mobile }}px;
    }

    .ai-hero-fullbleed__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
    }

    .ai-hero-fullbleed__subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-fullbleed-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.image %}
    <img
      src="{{ block.settings.image | image_url: width: 2400 }}"
      srcset="{{ block.settings.image | image_url: width: 800 }} 800w,
              {{ block.settings.image | image_url: width: 1200 }} 1200w,
              {{ block.settings.image | image_url: width: 1600 }} 1600w,
              {{ block.settings.image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      alt="{{ block.settings.image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.image.width }}"
      height="{{ block.settings.image.height }}"
      class="ai-hero-fullbleed__image-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="ai-hero-fullbleed__image-placeholder-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    </div>
  {% endif %}

  <div class="ai-hero-fullbleed__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-fullbleed__content-{{ ai_gen_id }}">
    {% if block.settings.label != blank %}
      <div class="ai-hero-fullbleed__label-{{ ai_gen_id }}">
        {{ block.settings.label }}
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-fullbleed__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <p class="ai-hero-fullbleed__subheadline-{{ ai_gen_id }}">
        {{ block.settings.subheadline }}
      </p>
    {% endif %}
  </div>
</div>

