{% doc %}
  @prompt
    Create a "Featured Article with Grid" section for a blog. The section should include: 1) A configurable section heading/title at the top (editable in theme editor). 2) One large featured/hero article (with big featured image, title, excerpt, date, author, and a "Read More" link). 3) Below the featured article, a 3-column grid of 3 smaller article cards (each with featured image, title, excerpt, date, and a read more link) — all pulled from a selected blog. 4) At the bottom, a "View All" button displayed as underlined text with no arrow, with a fully customizable URL field. All settings (section heading, blog selection, button label, button URL) should be configurable in the theme editor. Style it to match a premium, editorial aesthetic with clean typography and earthy/natural tones.
    
    please follow the instructions carefully , it should look like this with origin stories as heading and view more button with nutton setting its type - link secondary and its placement bottom or to right 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-article-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-featured-article-grid__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-featured-article-grid__header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 48px;
    {% if block.settings.button_placement == 'bottom' %}
      flex-direction: column;
      gap: 24px;
    {% else %}
      flex-direction: row;
      gap: 20px;
    {% endif %}
  }

  .ai-featured-article-grid__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
    {% if block.settings.button_placement == 'bottom' %}
      text-align: center;
      width: 100%;
    {% endif %}
  }

  .ai-featured-article-grid__view-more-{{ ai_gen_id }} {
    {% if block.settings.button_placement == 'bottom' %}
      width: 100%;
      text-align: center;
    {% else %}
      flex-shrink: 0;
    {% endif %}
  }

  .ai-featured-article-grid__view-more-link-{{ ai_gen_id }} {
    display: inline-block;
    text-decoration: none;
    transition: all 0.3s ease;
    {% if block.settings.button_type == 'link' %}
      font-size: 14px;
      color: {{ block.settings.link_color }};
      text-decoration: underline;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    {% else %}
      padding: 12px 24px;
      background-color: {{ block.settings.secondary_button_bg }};
      color: {{ block.settings.secondary_button_text }};
      border: {{ block.settings.secondary_button_border_width }}px solid {{ block.settings.secondary_button_border }};
      border-radius: {{ block.settings.secondary_button_radius }}px;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    {% endif %}
  }

  .ai-featured-article-grid__view-more-link-{{ ai_gen_id }}:hover {
    {% if block.settings.button_type == 'link' %}
      color: {{ block.settings.link_hover_color }};
    {% else %}
      background-color: {{ block.settings.secondary_button_hover_bg }};
      color: {{ block.settings.secondary_button_hover_text }};
      border-color: {{ block.settings.secondary_button_hover_border }};
    {% endif %}
  }

  .ai-featured-article-grid__featured-{{ ai_gen_id }} {
    margin-bottom: 60px;
  }

  .ai-featured-article-grid__featured-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-featured-article-grid__featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: 500px;
    overflow: hidden;
    margin-bottom: 24px;
    position: relative;
  }

  .ai-featured-article-grid__featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-featured-article-grid__featured-link-{{ ai_gen_id }}:hover .ai-featured-article-grid__featured-image-{{ ai_gen_id }} img {
    transform: scale(1.02);
  }

  .ai-featured-article-grid__featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-featured-article-grid__featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-featured-article-grid__featured-meta-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
    font-size: 14px;
    color: {{ block.settings.meta_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-featured-article-grid__featured-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.featured_title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    line-height: 1.3;
  }

  .ai-featured-article-grid__featured-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .ai-featured-article-grid__read-more-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 14px;
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
  }

  .ai-featured-article-grid__read-more-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-featured-article-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .ai-featured-article-grid__card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-featured-article-grid__card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 280px;
    overflow: hidden;
    margin-bottom: 16px;
    position: relative;
  }

  .ai-featured-article-grid__card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-featured-article-grid__card-{{ ai_gen_id }}:hover .ai-featured-article-grid__card-image-{{ ai_gen_id }} img {
    transform: scale(1.02);
  }

  .ai-featured-article-grid__card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-featured-article-grid__card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-featured-article-grid__card-meta-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
    font-size: 12px;
    color: {{ block.settings.meta_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-featured-article-grid__card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    line-height: 1.3;
  }

  .ai-featured-article-grid__card-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_excerpt_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin-bottom: 12px;
  }

  @media screen and (max-width: 989px) {
    .ai-featured-article-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }

    .ai-featured-article-grid__featured-image-{{ ai_gen_id }} {
      height: 400px;
    }

    .ai-featured-article-grid__card-image-{{ ai_gen_id }} {
      height: 240px;
    }

    .ai-featured-article-grid__header-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 24px;
    }

    .ai-featured-article-grid__heading-{{ ai_gen_id }} {
      text-align: center;
      width: 100%;
    }

    .ai-featured-article-grid__view-more-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-article-grid-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-featured-article-grid__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-featured-article-grid__header-{{ ai_gen_id }} {
      margin-bottom: 32px;
    }

    .ai-featured-article-grid__featured-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-featured-article-grid__featured-image-{{ ai_gen_id }} {
      height: 300px;
    }

    .ai-featured-article-grid__featured-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_title_size | times: 0.7 }}px;
    }

    .ai-featured-article-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-featured-article-grid__card-image-{{ ai_gen_id }} {
      height: 220px;
    }

    .ai-featured-article-grid__card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<featured-article-grid-{{ ai_gen_id }} class="ai-featured-article-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-article-grid__container-{{ ai_gen_id }}">
    <div class="ai-featured-article-grid__header-{{ ai_gen_id }}">
      {% if block.settings.section_heading != blank %}
        <h2 class="ai-featured-article-grid__heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
      {% endif %}

      {% if block.settings.view_more_url != blank %}
        <div class="ai-featured-article-grid__view-more-{{ ai_gen_id }}">
          <a href="{{ block.settings.view_more_url }}" class="ai-featured-article-grid__view-more-link-{{ ai_gen_id }}">
            {{ block.settings.view_more_label }}
          </a>
        </div>
      {% endif %}
    </div>

    {% if block.settings.blog != blank %}
      {% assign articles = block.settings.blog.articles %}
      {% assign featured_article = articles.first %}

      {% if featured_article %}
        <div class="ai-featured-article-grid__featured-{{ ai_gen_id }}">
          <a href="{{ featured_article.url }}" class="ai-featured-article-grid__featured-link-{{ ai_gen_id }}">
            <div class="ai-featured-article-grid__featured-image-{{ ai_gen_id }}">
              {% if featured_article.image %}
                <img
                  src="{{ featured_article.image | image_url: width: 1400 }}"
                  alt="{{ featured_article.image.alt | escape }}"
                  loading="lazy"
                  width="{{ featured_article.image.width }}"
                  height="{{ featured_article.image.height }}"
                >
              {% else %}
                <div class="ai-featured-article-grid__featured-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-featured-article-grid__featured-meta-{{ ai_gen_id }}">
              <span>{{ featured_article.published_at | date: '%B %d, %Y' }}</span>
              {% if featured_article.author != blank %}
                <span>{{ featured_article.author }}</span>
              {% endif %}
            </div>

            <h3 class="ai-featured-article-grid__featured-title-{{ ai_gen_id }}">{{ featured_article.title }}</h3>

            {% if featured_article.excerpt != blank %}
              <div class="ai-featured-article-grid__featured-excerpt-{{ ai_gen_id }}">
                {{ featured_article.excerpt | strip_html | truncate: 200 }}
              </div>
            {% endif %}

            <span class="ai-featured-article-grid__read-more-{{ ai_gen_id }}">Read More</span>
          </a>
        </div>
      {% endif %}

      {% if articles.size > 1 %}
        <div class="ai-featured-article-grid__grid-{{ ai_gen_id }}">
          {% for article in articles offset: 1 limit: 3 %}
            <a href="{{ article.url }}" class="ai-featured-article-grid__card-{{ ai_gen_id }}">
              <div class="ai-featured-article-grid__card-image-{{ ai_gen_id }}">
                {% if article.image %}
                  <img
                    src="{{ article.image | image_url: width: 600 }}"
                    alt="{{ article.image.alt | escape }}"
                    loading="lazy"
                    width="{{ article.image.width }}"
                    height="{{ article.image.height }}"
                  >
                {% else %}
                  <div class="ai-featured-article-grid__card-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-featured-article-grid__card-meta-{{ ai_gen_id }}">
                <span>{{ article.published_at | date: '%B %d, %Y' }}</span>
              </div>

              <h4 class="ai-featured-article-grid__card-title-{{ ai_gen_id }}">{{ article.title }}</h4>

              {% if article.excerpt != blank %}
                <div class="ai-featured-article-grid__card-excerpt-{{ ai_gen_id }}">
                  {{ article.excerpt | strip_html | truncate: 120 }}
                </div>
              {% endif %}

              <span class="ai-featured-article-grid__read-more-{{ ai_gen_id }}">Read More</span>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</featured-article-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedArticleGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('featured-article-grid-{{ ai_gen_id }}', FeaturedArticleGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured article grid",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "section_heading",
      "label": "Section heading",
      "default": "Origin Stories"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "header",
      "content": "View more button"
    },
    {
      "type": "inline_richtext",
      "id": "view_more_label",
      "label": "Button label",
      "default": "View More"
    },
    {
      "type": "url",
      "id": "view_more_url",
      "label": "Button URL"
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Button type",
      "options": [
        {
          "value": "link",
          "label": "Link"
        },
        {
          "value": "secondary",
          "label": "Secondary button"
        }
      ],
      "default": "secondary"
    },
    {
      "type": "select",
      "id": "button_placement",
      "label": "Button placement",
      "options": [
        {
          "value": "right",
          "label": "Right of heading"
        },
        {
          "value": "bottom",
          "label": "Below heading"
        }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fafaf5"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Section heading",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Article titles",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Date and author",
      "default": "#6b5345"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Links",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
