    },
    {
      "type": "color",
      "id": "secondary_button_text",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "secondary_button_border",
      "label": "Border",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "secondary_button_hover_bg",
      "label": "Hover background",
      "default": "#fff8e7"
    },
    {
      "type": "color",
      "id": "secondary_button_hover_text",
      "label": "Hover text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "secondary_button_hover_border",
      "label": "Hover border",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Section heading font",
      "default": "cormorant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
