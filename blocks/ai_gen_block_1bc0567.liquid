{% doc %}
  @prompt
    Create a premium editorial "Our Process" section for a luxury honey brand product page. The section should have a refined, understated heading like "What Goes Into Every Drop" or "Crafted Without Compromise" — no mention of price or cost. It should display 6 process/quality pillars as a clean multi-column grid (2 or 3 columns), each with a small icon or decorative element, a short bold label, and 1–2 lines of editorial copy. The six pillars are: 1. Low-Volume Harvesting — "Sourced from small apiaries to ensure quality over quantity." 2. Cold-Extracted — "Never heated, so every enzyme, antioxidant, and flavour note stays intact." 3. Small-Batch Processing — "Each batch is handled individually, not industrially." 4. Traceable Sourcing — "We know every hive, every region, every season." 5. Purity Tested — "Third-party tested for adulteration, moisture, and contaminants." 6. Considered Packaging — "Glass-first, minimal waste, designed to last on your shelf." The aesthetic should be warm, editorial, and premium — warm honey tones, clean typography, generous whitespace. No price language anywhere. This should feel like a brand story section, not a justification., change the $ icon to droplet icon 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-process-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-process-section__inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-process-section__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    line-height: 1.2;
  }

  .ai-process-section__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  .ai-process-section__pillar-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.pillar_gap }}px;
  }

  .ai-process-section__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-process-section__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: {{ block.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-process-section__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    color: {{ block.settings.label_color }};
    margin: 0;
    line-height: 1.3;
    letter-spacing: {{ block.settings.label_letter_spacing }};
  }

  .ai-process-section__copy-{{ ai_gen_id }} {
    font-size: {{ block.settings.copy_size }}px;
    color: {{ block.settings.copy_color }};
    line-height: {{ block.settings.copy_line_height }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-process-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px {{ block.settings.section_padding_horizontal | times: 0.6 }}px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-process-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-process-section__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-process-section__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-process-section__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.9 }}px;
    }

    .ai-process-section__copy-{{ ai_gen_id }} {
      font-size: {{ block.settings.copy_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-process-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-process-section__inner-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-process-section__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-process-section__grid-{{ ai_gen_id }}">
      <div class="ai-process-section__pillar-{{ ai_gen_id }}">
        <div class="ai-process-section__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3 class="ai-process-section__label-{{ ai_gen_id }}">{{ block.settings.pillar_1_label }}</h3>
        <p class="ai-process-section__copy-{{ ai_gen_id }}">{{ block.settings.pillar_1_copy }}</p>
      </div>

      <div class="ai-process-section__pillar-{{ ai_gen_id }}">
        <div class="ai-process-section__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
          </svg>
        </div>
        <h3 class="ai-process-section__label-{{ ai_gen_id }}">{{ block.settings.pillar_2_label }}</h3>
        <p class="ai-process-section__copy-{{ ai_gen_id }}">{{ block.settings.pillar_2_copy }}</p>
      </div>

      <div class="ai-process-section__pillar-{{ ai_gen_id }}">
        <div class="ai-process-section__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
        </div>
        <h3 class="ai-process-section__label-{{ ai_gen_id }}">{{ block.settings.pillar_3_label }}</h3>
        <p class="ai-process-section__copy-{{ ai_gen_id }}">{{ block.settings.pillar_3_copy }}</p>
      </div>

      <div class="ai-process-section__pillar-{{ ai_gen_id }}">
        <div class="ai-process-section__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3 class="ai-process-section__label-{{ ai_gen_id }}">{{ block.settings.pillar_4_label }}</h3>
        <p class="ai-process-section__copy-{{ ai_gen_id }}">{{ block.settings.pillar_4_copy }}</p>
      </div>

      <div class="ai-process-section__pillar-{{ ai_gen_id }}">
        <div class="ai-process-section__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <h3 class="ai-process-section__label-{{ ai_gen_id }}">{{ block.settings.pillar_5_label }}</h3>
        <p class="ai-process-section__copy-{{ ai_gen_id }}">{{ block.settings.pillar_5_copy }}</p>
      </div>

      <div class="ai-process-section__pillar-{{ ai_gen_id }}">
        <div class="ai-process-section__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h3 class="ai-process-section__label-{{ ai_gen_id }}">{{ block.settings.pillar_6_label }}</h3>
        <p class="ai-process-section__copy-{{ ai_gen_id }}">{{ block.settings.pillar_6_copy }}</p>
      </div>
    </div>
  </div>
</div>

