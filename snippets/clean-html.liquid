              {%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {{ cleaned_part }}
      {%- endfor -%}
    {%- endcapture -%}
  {%- endif -%}

  {%- comment -%} Remove PayU preconnect link entirely if not needed {%- endcomment -%}
  {%- if cleaned_html contains 'https://ce-partnerapilayer.payu.in' -%}
    {%- assign parts = cleaned_html | split: 'https://ce-partnerapilayer.payu.in' -%}
    {%- capture cleaned_html -%}
      {%- for part in parts -%}
        {%- assign cleaned_part = part -%}
        {%- unless forloop.first -%}
          {%- assign subparts = cleaned_part | split: '>' -%}
          {%- capture cleaned_part -%}
            {%- for sub in subparts offset:1 -%}
              {{ sub }}{%- unless forloop.last -%}>{%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {%- unless forloop.last -%}
          {%- assign subparts = cleaned_part | split: '<link' -%}
          {%- capture cleaned_part -%}
            {%- for sub in subparts -%}
