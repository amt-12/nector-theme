{%- comment -%} 5. Optimize Instafeed CSS based on page template {%- endcomment -%}
{%- if template.name == 'index' -%}
  {%- if cleaned_html contains 'instafeed-17.9.0.css' -%}
    {%- assign parts = cleaned_html | split: 'instafeed-17.9.0.css' -%}
    {%- capture cleaned_html -%}
      {{ parts[0] }}
      {%- for part in parts offset:1 -%}
        instafeed-17.9.0.css
        {%- assign subparts = part | split: '>' -%}
        {%- assign tag_content = subparts[0] -%}
        {%- assign deferred_tag = tag_content -%}
        {%- if deferred_tag contains 'rel="stylesheet"' -%}
          {%- if deferred_tag contains 'media=' -%}
            {%- assign deferred_tag = deferred_tag | replace: 'media="all"', 'media="print" onload="this.media=\'all\'"' -%}
            {%- assign deferred_tag = deferred_tag | replace: "media='all'", 'media="print" onload="this.media=\'all\'"' -%}
          {%- else -%}
            {%- assign deferred_tag = deferred_tag | replace: 'rel="stylesheet"', 'rel="stylesheet" media="print" onload="this.media=\'all\'"' -%}
          {%- endif -%}
        {%- endif -%}
        {{ deferred_tag }}>
        {%- for sub in subparts offset:1 -%}
          {{ sub }}{%- unless forloop.last -%}>{%- endunless -%}
        {%- endfor -%}
      {%- endfor -%}
    {%- endcapture -%}
  {%- endif -%}
{%- else -%}
  {%- if cleaned_html contains 'instafeed-17.9.0.css' -%}
    {%- assign parts = cleaned_html | split: 'instafeed-17.9.0.css' -%}
    {%- capture cleaned_html -%}
      {%- for part in parts -%}
        {%- assign cleaned_part = part -%}
        {%- unless forloop.first -%}
          {%- assign subparts = cleaned_part | split: '>' -%}
          {%- capture cleaned_part -%}
            {%- for sub in subparts offset:1 -%}
              {{ sub }}{%- unless forloop.last -%}>{%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {%- unless forloop.last -%}
          {%- assign subparts = cleaned_part | split: '<link' -%}
          {%- capture cleaned_part -%}
            {%- for sub in subparts -%}
              {%- unless forloop.last -%}
                {{ sub }}{%- unless forloop.index == subparts.size | minus: 1 -%}<link{%- endunless -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {{ cleaned_part }}
      {%- endfor -%}
    {%- endcapture -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} 6. Handle PayU OTP Assets {%- endcomment -%}
{%- if needs_otp_login -%}
  {%- comment -%} Defer PayU styles if login is needed {%- endcomment -%}
  {%- if cleaned_html contains 'payu-login.css' -%}
    {%- assign parts = cleaned_html | split: 'payu-login.css' -%}
    {%- capture cleaned_html -%}
      {{ parts[0] }}
      {%- for part in parts offset:1 -%}
        payu-login.css
        {%- assign subparts = part | split: '>' -%}
        {%- assign tag_content = subparts[0] -%}
        {%- assign deferred_tag = tag_content -%}
        {%- if deferred_tag contains 'rel="stylesheet"' -%}
          {%- if deferred_tag contains 'media=' -%}
            {%- assign deferred_tag = deferred_tag | replace: 'media="all"', 'media="print" onload="this.media=\'all\'"' -%}
            {%- assign deferred_tag = deferred_tag | replace: "media='all'", 'media="print" onload="this.media=\'all\'"' -%}
          {%- else -%}
            {%- assign deferred_tag = deferred_tag | replace: 'rel="stylesheet"', 'rel="stylesheet" media="print" onload="this.media=\'all\'"' -%}
          {%- endif -%}
        {%- endif -%}
        {{ deferred_tag }}>
        {%- for sub in subparts offset:1 -%}
          {{ sub }}{%- unless forloop.last -%}>{%- endunless -%}
        {%- endfor -%}
      {%- endfor -%}
    {%- endcapture -%}
  {%- endif -%}
{%- else -%}
  {%- comment -%} Remove PayU iframe tag if not needed {%- endcomment -%}
  {%- if cleaned_html contains 'payUCenteredIframe' -%}
    {%- assign parts = cleaned_html | split: 'payUCenteredIframe' -%}
    {%- capture cleaned_html -%}
      {%- for part in parts -%}
        {%- assign cleaned_part = part -%}
        {%- unless forloop.first -%}
          {%- assign subparts = cleaned_part | split: '</iframe>' -%}
          {%- capture cleaned_part -%}
            {%- for sub in subparts offset:1 -%}
              {{ sub }}{%- unless forloop.last -%}</iframe>{%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {%- unless forloop.last -%}
          {%- assign subparts = cleaned_part | split: '<iframe' -%}
          {%- capture cleaned_part -%}
            {%- for sub in subparts -%}
              {%- unless forloop.last -%}
                {{ sub }}{%- unless forloop.index == subparts.size | minus: 1 -%}<iframe{%- endunless -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {{ cleaned_part }}
      {%- endfor -%}
    {%- endcapture -%}
  {%- endif -%}

  {%- comment -%} Remove window.payU script tag if not needed {%- endcomment -%}
  {%- if cleaned_html contains 'window.payU = window.payU || {}' -%}
    {%- assign parts = cleaned_html | split: 'window.payU = window.payU || {}' -%}
    {%- capture cleaned_html -%}
      {%- for part in parts -%}
        {%- assign cleaned_part = part -%}
        {%- unless forloop.first -%}
          {%- assign subparts = cleaned_part | split: '</script>' -%}
          {%- capture cleaned_part -%}
            {%- for sub in subparts offset:1 -%}
              {{ sub }}{%- unless forloop.last -%}</script>{%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {%- unless forloop.last -%}
          {%- assign subparts = cleaned_part | split: '<script' -%}
          {%- capture cleaned_part -%}
            {%- for sub in subparts -%}
              {%- unless forloop.last -%}
                {{ sub }}{%- unless forloop.index == subparts.size | minus: 1 -%}<script{%- endunless -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {{ cleaned_part }}
      {%- endfor -%}
    {%- endcapture -%}
  {%- endif -%}

  {%- comment -%} Remove PayU styles entirely if not needed {%- endcomment -%}
  {%- if cleaned_html contains 'payu-login.css' -%}
    {%- assign parts = cleaned_html | split: 'payu-login.css' -%}
