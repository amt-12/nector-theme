            {%- endfor -%}
          {%- endcapture -%}
        {%- endunless -%}
        {{ cleaned_part }}
      {%- endfor -%}
    {%- endcapture -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} 7. Remove redundant preconnect to cdn.shopify.com {%- endcomment -%}
{%- assign cleaned_html = cleaned_html | replace: 'rel="dns-prefetch preconnect" href="https://cdn.shopify.com"', 'rel="dns-prefetch" href="https://cdn.shopify.com"' -%}
{%- assign cleaned_html = cleaned_html | replace: 'rel="dns-prefetch preconnect" href="https://cdn.shopify.com" crossorigin=""', 'rel="dns-prefetch" href="https://cdn.shopify.com"' -%}
{%- assign cleaned_html = cleaned_html | replace: 'rel="dns-prefetch preconnect" href="https://cdn.shopify.com" crossorigin', 'rel="dns-prefetch" href="https://cdn.shopify.com"' -%}
