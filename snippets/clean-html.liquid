    {%- endcapture -%}
  {%- endif -%}

  {%- comment -%} Remove PayU scripts entirely if not needed {%- endcomment -%}
  {%- if cleaned_html contains 'payu-login.js' -%}
    {%- assign parts = cleaned_html | split: 'payu-login.js' -%}
